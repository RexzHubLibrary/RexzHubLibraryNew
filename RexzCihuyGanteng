function TabClass:AddToggle(text, iconId, defaultState, callback)
    local lib    = self.Library
    local state  = defaultState or false
    local action = callback or function() end

    local El = Instance.new("TextButton")
    El.Name = text .. "_Toggle"
    El.Size = UDim2.new(1, -4, 0, 36)
    El.BackgroundColor3 = lib.Theme.Element
    El.BorderSizePixel = 0
    El.Text = ""
    El.AutoButtonColor = false
    El.Parent = self.ScrollBox
    Corner(El, 6)
    Stroke(El, lib.Theme.Stroke, 1)

    local Icon = nil
    if iconId then
        Icon = Instance.new("ImageLabel")
        Icon.Name = "ToggleIcon"
        Icon.Size = UDim2.new(0, 14, 0, 14)
        Icon.Position = UDim2.new(0, 10, 0.5, -7)
        Icon.BackgroundTransparency = 1
        Icon.Image = ResolveIcon(iconId)
        Icon.ImageColor3 = lib.Theme.Icon
        Icon.Parent = El
    end

    local Label = Instance.new("TextLabel")
    Label.Name = "ToggleLabel"
    Label.Size = UDim2.new(1, iconId and -72 or -52, 1, 0)
    Label.Position = UDim2.new(0, iconId and 30 or 10, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = lib.Theme.Text
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = El

    -- Indicator box
    local Ind = Instance.new("Frame")
    Ind.Name = "IndicatorFrame"
    Ind.Size = UDim2.new(0, 26, 0, 26)
    Ind.Position = UDim2.new(1, -34, 0.5, -13)
    Ind.BackgroundColor3 = state and lib.Theme.ToggleOnBg or lib.Theme.ToggleOffBg
    Ind.BorderSizePixel = 0
    Ind.Parent = El
    Corner(Ind, 6)
    local IndStroke = Stroke(Ind, state and lib.Theme.Accent or lib.Theme.Stroke, 1.2)

    local RLogo = Instance.new("TextLabel")
    RLogo.Name = "RLogo"
    RLogo.Size = UDim2.new(1, 0, 1, 0)
    RLogo.BackgroundTransparency = 1
    RLogo.Text = "R"
    RLogo.TextColor3 = state and lib.Theme.Accent or lib.Theme.Muted
    RLogo.TextSize = 13
    RLogo.Font = Enum.Font.GothamBold
    RLogo.TextXAlignment = Enum.TextXAlignment.Center
    RLogo.TextYAlignment = Enum.TextYAlignment.Center
    RLogo.Parent = Ind

    local function UpdateVisual(animate)
        local bg  = state and lib.Theme.ToggleOnBg  or lib.Theme.ToggleOffBg
        local col = state and lib.Theme.Accent or lib.Theme.Stroke
        local txt = state and lib.Theme.Accent or lib.Theme.Muted
        if animate then
            TweenService:Create(Ind,      TweenInfo.new(0.18), { BackgroundColor3 = bg  }):Play()
            TweenService:Create(IndStroke,TweenInfo.new(0.18), { Color = col }):Play()
            TweenService:Create(RLogo,    TweenInfo.new(0.18), { TextColor3 = txt }):Play()
        else
            Ind.BackgroundColor3 = bg
            IndStroke.Color = col
            RLogo.TextColor3 = txt
        end
    end

    UpdateVisual(false)

    El.MouseButton1Click:Connect(function()
        state = not state
        lib.ToggleStates[text] = state
        UpdateVisual(true)
        pcall(action, state)
    end)

    lib.ToggleStates[text] = state
    lib.ToggleRegistry[text] = {
        SetState = function(newState, fire)
            state = newState and true or false
            lib.ToggleStates[text] = state
            UpdateVisual(true)
            if fire then pcall(action, state) end
        end
    }

    table.insert(lib.ControlRegistry, {
        Kind = "Toggle", Root = El, Title = Label, Icon = Icon,
        Text = Label, Indicator = Ind, RLogo = RLogo, State = state
    })
    table.insert(self.Elements, { Name = text, Instance = El })
end

