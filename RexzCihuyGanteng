function TabClass:AddSlider(text, min, max, default, callback)
    local action = callback or function() end
    local library = self.Library
    local value = math.clamp(default or min, min, max)

    local SliderElement = Instance.new("Frame")
    SliderElement.Size = UDim2.new(1, -4, 0, 45)
    SliderElement.BackgroundColor3 = Color3.fromRGB(26, 26, 33)
    SliderElement.Parent = self.ScrollBox

    local SCorn = Instance.new("UICorner") or Instance.new("UICorner", SliderElement)
    SCorn.CornerRadius = UDim.new(0, 6)

    local SStroke = Instance.new("UIStroke") or Instance.new("UIStroke", SliderElement)
    SStroke.Color = Color3.fromRGB(35, 35, 45)

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0, 200, 0, 20)
    Label.Position = UDim2.new(0, 12, 0, 4)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(215, 215, 225)
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = SliderElement

    local ValLabel = Instance.new("TextLabel")
    ValLabel.Size = UDim2.new(0, 60, 0, 20)
    ValLabel.Position = UDim2.new(1, -72, 0, 4)
    ValLabel.BackgroundTransparency = 1
    ValLabel.Text = tostring(value)
    ValLabel.TextColor3 = library.AccentColor
    ValLabel.TextSize = 12
    ValLabel.Font = Enum.Font.GothamBold
    ValLabel.TextXAlignment = Enum.TextXAlignment.Right
    ValLabel.Parent = SliderElement

    local Track = Instance.new("Frame")
    Track.Size = UDim2.new(1, -24, 0, 6)
    Track.Position = UDim2.new(0, 12, 0, 28)
    Track.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    Track.Parent = SliderElement
    Instance.new("UICorner", Track).CornerRadius = UDim.new(0, 3)

    local Fill = Instance.new("Frame")
    Fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    Fill.BackgroundColor3 = library.AccentColor
    Fill.Parent = Track
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(0, 3)

    local Dragging = false
    local function UpdateSlider()
        local mouseX = math.clamp(Mouse.X - Track.AbsolutePosition.X, 0, Track.AbsoluteSize.X)
        local ratio = mouseX / Track.AbsoluteSize.X
        value = math.floor(min + (max - min) * ratio)
        ValLabel.Text = tostring(value)
        Fill.Size = UDim2.new(ratio, 0, 1, 0)
        pcall(action, value)
    end

    SliderElement.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = true UpdateSlider() end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then UpdateSlider() end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end
    end)

    table.insert(self.Elements, { Name = text, Instance = SliderElement, UpdateTheme = function() ValLabel.TextColor3 = library.AccentColor Fill.BackgroundColor3 = library.AccentColor end })
end

