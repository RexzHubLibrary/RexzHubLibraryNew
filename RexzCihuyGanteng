--  APPLY THEME
-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function RexzLibrary:ApplyTheme(theme)
    theme = theme or self.Theme
    self.Theme = theme

    if self.MainFrame then
        self.MainFrame.BackgroundColor3 = theme.Background
        local s = self.MainFrame:FindFirstChildOfClass("UIStroke")
        if s then s.Color = theme.Stroke end
    end

    if self.TopBar then
        self.TopBar.BackgroundColor3 = theme.Topbar
        local fix = self.TopBar:FindFirstChild("TopFix")
        if fix then fix.BackgroundColor3 = theme.Topbar end
    end

    if self.SidebarBg then
        self.SidebarBg.BackgroundColor3 = theme.Sidebar
    end

    if self.SearchFrame then
        self.SearchFrame.BackgroundColor3 = theme.Element
        local s = self.SearchFrame:FindFirstChildOfClass("UIStroke")
        if s then s.Color = theme.Stroke end
        local ic = self.SearchFrame:FindFirstChild("SearchIcon")
        if ic then ic.ImageColor3 = theme.Muted end
        local box = self.SearchFrame:FindFirstChild("SearchInput")
        if box then
            box.TextColor3 = theme.Text
            box.PlaceholderColor3 = theme.Muted
        end
    end

    for _, obj in ipairs(self.Sidebar:GetChildren()) do
        if obj.Name:sub(1,9) == "Category_" then
            local line = obj:FindFirstChildWhichIsA("Frame")
            if line then line.BackgroundColor3 = theme.Stroke end
            local lbl = obj:FindFirstChildWhichIsA("TextLabel")
            if lbl then lbl.TextColor3 = theme.Muted end
        end
    end

    for _, tab in ipairs(self.Tabs or {}) do
        if tab.BackgroundColor then
            if tab == self.CurrentTab then
                tab.BackgroundColor.BackgroundColor3 = theme.TabActive
                tab.Label.TextColor3 = theme.Accent
                if tab.Icon then tab.Icon.ImageColor3 = theme.Accent end
            else
                tab.BackgroundColor.BackgroundColor3 = theme.Element
                tab.Label.TextColor3 = theme.TextDim
                if tab.Icon then tab.Icon.ImageColor3 = theme.Icon end
            end
        end
    end

    for _, ref in ipairs(self.ControlRegistry or {}) do
        if ref.Root and ref.Root.Parent then
            local bg = theme.Element
            if ref.Kind == "Dropdown" then bg = theme.DropdownBg
            elseif ref.Kind == "Input"    then bg = theme.InputBg
            elseif ref.Kind == "Label"    then bg = theme.LabelBg
            end
            ref.Root.BackgroundColor3 = bg
            local s = ref.Root:FindFirstChildOfClass("UIStroke")
            if s then s.Color = theme.Stroke end
        end
        if ref.Title then ref.Title.TextColor3 = theme.Text end
        if ref.Icon  then ref.Icon.ImageColor3  = theme.Icon  end

        if ref.Kind == "Button" then
            if ref.Text then ref.Text.TextColor3 = theme.Text end
        elseif ref.Kind == "Toggle" then
            if ref.Text then ref.Text.TextColor3 = theme.Text end
        elseif ref.Kind == "Dropdown" then
            if ref.ValueLabel then ref.ValueLabel.TextColor3 = theme.TextDim end
            if ref.Arrow       then ref.Arrow.TextColor3      = theme.Muted   end
        elseif ref.Kind == "Input" then
            if ref.Box then
                ref.Box.TextColor3        = theme.Text
                ref.Box.PlaceholderColor3 = theme.Muted
            end
        elseif ref.Kind == "Label" then
            if ref.SubText then ref.SubText.TextColor3 = theme.Muted end
        end
    end
end

