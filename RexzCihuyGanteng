function TabClass:AddKeybind(text, defaultKey, callback, key)
	local action = callback or function() end
	local regKey = key or self.Library:_key(text)
	local currentKey = defaultKey or Enum.KeyCode.RightAlt
	local waitingForBind = false

	local row = new("TextButton", {
		Size = UDim2.new(1, -4, 0, 36),
		BackgroundColor3 = Color3.fromRGB(26, 26, 33),
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		Parent = self.ScrollBox,
	})
	corner(row, 6)
	stroke(row, Color3.fromRGB(35, 35, 45), 1)

	new("TextLabel", {
		Size = UDim2.new(1, -110, 1, 0),
		Position = UDim2.new(0, 12, 0, 0),
		BackgroundTransparency = 1,
		Text = text,
		TextColor3 = Color3.fromRGB(215, 215, 225),
		TextSize = 12,
		Font = Enum.Font.GothamMedium,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = row,
	})

	local keyLabel = new("TextLabel", {
		Size = UDim2.new(0, 80, 0, 20),
		Position = UDim2.new(1, -92, 0.5, -10),
		BackgroundTransparency = 1,
		Text = currentKey.Name,
		TextColor3 = self.Library.AccentColor,
		TextSize = 11,
		Font = Enum.Font.GothamBold,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = row,
	})

	local function apply(v, fire)
		if typeof(v) == "EnumItem" and v.EnumType == Enum.KeyCode then
			currentKey = v
			keyLabel.Text = currentKey.Name
			if fire then safeCall(action, currentKey) end
		end
	end

	self.Library._registry[regKey] = {
		Type = "Keybind",
		Apply = apply,
		Get = function() return currentKey.Name end,
	}

	self.Library:_track(row.MouseButton1Click:Connect(function()
		waitingForBind = true
		keyLabel.Text = "..."
	end))

	self.Library:_track(UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if waitingForBind and input.UserInputType == Enum.UserInputType.Keyboard then
			waitingForBind = false
			currentKey = input.KeyCode
			keyLabel.Text = currentKey.Name
			return
		end

		if input.KeyCode == currentKey then
			safeCall(action)
		end
	end))

	table.insert(self.Elements, { Name = text, Instance = row })
	return {
		Set = function(v) apply(v, false) end,
		Get = function() return currentKey end,
	}
end

function TabClass:AddColorPicker(text, defaultColor, callback, key)
	local action = callback or function() end
	local regKey = key or self.Library:_key(text)
	local value = defaultColor or self.Library.AccentColor
	local dragging = false

	local row = new("Frame", {
		Size = UDim2.new(1, -4, 0, 50),
		BackgroundColor3 = Color3.fromRGB(26, 26, 33),
		BorderSizePixel = 0,
		Parent = self.ScrollBox,
	})
	corner(row, 6)
	stroke(row, Color3.fromRGB(35, 35, 45), 1)

	new("TextLabel", {
		Size = UDim2.new(0, 120, 1, 0),
		Position = UDim2.new(0, 12, 0, 0),
		BackgroundTransparency = 1,
		Text = text,
		TextColor3 = Color3.fromRGB(215, 215, 225),
		TextSize = 12,
		Font = Enum.Font.GothamMedium,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = row,
	})

	local track = new("Frame", {
		Size = UDim2.new(1, -170, 0, 10),
		Position = UDim2.new(0, 150, 0.5, -5),
		BackgroundColor3 = Color3.fromRGB(55, 55, 65),
		BorderSizePixel = 0,
		Parent = row,
	})
	corner(track, 4)

	local fill = new("Frame", {
		Size = UDim2.new(0, 0, 1, 0),
		BackgroundColor3 = value,
		BorderSizePixel = 0,
		Parent = track,
	})
	corner(fill, 4)

	local pin = new("TextButton", {
		Size = UDim2.new(0, 14, 0, 14),
		Position = UDim2.new(0, -7, 0.5, -7),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Text = "",
		AutoButtonColor = false,
		Parent = track,
	})
	corner(pin, 14)

	local preview = new("Frame", {
		Size = UDim2.new(0, 24, 0, 24),
		Position = UDim2.new(1, -36, 0.5, -12),
		BackgroundColor3 = value,
		BorderSizePixel = 0,
		Parent = row,
	})
	corner(preview, 6)

	local function apply(v, fire)
		if typeof(v) == "Color3" then
			value = v
			preview.BackgroundColor3 = value
			fill.BackgroundColor3 = value
			if track.AbsoluteSize.X > 0 then
				pin.Position = UDim2.new(0, math.floor((value.R) * track.AbsoluteSize.X) - 7, 0.5, -7)
			end
			if fire then
				safeCall(action, value)
			end
		end
	end

	self.Library._registry[regKey] = {
		Type = "ColorPicker",
		Apply = apply,
		Get = function()
			return { value.R, value.G, value.B }
		end,
		UpdateTheme = function()
			-- keep current selected color, do not override
		end,
	}

	self.Library:_track(pin.MouseButton1Down:Connect(function()
		dragging = true
	end))
	self.Library:_track(UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local x = math.clamp(getMouseXY() - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
			local pct = x / track.AbsoluteSize.X
			local selectedColor = Color3.fromHSV(pct, 1, 1)
			value = selectedColor
			pin.Position = UDim2.new(pct, -7, 0.5, -7)
			fill.Size = UDim2.new(pct, 0, 1, 0)
			preview.BackgroundColor3 = selectedColor
			safeCall(action, selectedColor)
		end
	end))
	self:_track(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end))

	table.insert(self.Elements, {
		Name = text,
		Instance = row,
		UpdateTheme = function()
			preview.BackgroundColor3 = value
			fill.BackgroundColor3 = value
		end,
	})

	return {
		Set = function(v) apply(v, false) end,
		Get = function() return value end,
	}
end

return RexzLibrary
