function RexzLibrary:CreateResizeGrip(parent)
    local grip = Instance.new("TextButton")
    grip.Size = UDim2.new(0, 20, 0, 20)
    grip.Position = UDim2.new(1, -20, 1, -20)
    grip.BackgroundTransparency = 1
    grip.Text = "◢"
    grip.TextColor3 = Color3.fromRGB(80, 80, 95)
    grip.TextSize = 14
    grip.Font = Enum.Font.GothamBold
    grip.Parent = parent
    
    local resizing = false
    local startPos = nil
    local startSize = nil
    
    grip.MouseButton1Down:Connect(function()
        resizing = true
        startPos = UserInputService:GetMouseLocation()
        startSize = self.MainFrame.Size
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            if self.Minimized or self.Hidden then return end
            local currentPos = UserInputService:GetMouseLocation()
            local delta = currentPos - startPos
            local newWidth = math.max(400, startSize.X.Offset + delta.X)
            local newHeight = math.max(300, startSize.Y.Offset + delta.Y)
            self.WindowSize = UDim2.new(0, newWidth, 0, newHeight)
            self.MainFrame.Size = self.WindowSize
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = false
        end
    end)
    
    self.ResizeGrip = grip
end

