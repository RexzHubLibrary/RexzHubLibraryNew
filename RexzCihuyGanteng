			BackgroundTransparency = 1,
			Image = "rbxassetid://" .. tostring(iconId),
			ImageColor3 = Color3.fromRGB(210, 210, 220),
			Parent = row,
		})
	end

	new("TextLabel", {
		Size = UDim2.new(1, iconId and -76 or -56, 1, 0),
		Position = UDim2.new(0, iconId and 34 or 12, 0, 0),
		BackgroundTransparency = 1,
		Text = text,
		TextColor3 = Color3.fromRGB(215, 215, 225),
		TextSize = 12,
		Font = Enum.Font.GothamMedium,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = row,
	})

	local indicator = new("Frame", {
		Size = UDim2.new(0, 24, 0, 24),
		Position = UDim2.new(1, -36, 0.5, -12),
		Parent = row,
	})
	corner(indicator, 6)

	local indStroke = stroke(indicator, Color3.fromRGB(45, 45, 55), 1.2)

	local check = new("TextLabel", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text = "✓",
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextSize = 12,
		Font = Enum.Font.GothamBold,
		Parent = indicator,
	})

	local function updateVisual(animate)
		local targetBg = state and Color3.fromRGB(35, 30, 45) or Color3.fromRGB(20, 20, 25)
		local targetStroke = state and self.Library.AccentColor or Color3.fromRGB(45, 45, 55)
		check.Visible = state

		if animate then
			TweenService:Create(indicator, TweenInfo.new(0.15), { BackgroundColor3 = targetBg }):Play()
			TweenService:Create(indStroke, TweenInfo.new(0.15), { Color = targetStroke }):Play()
		else
			indicator.BackgroundColor3 = targetBg
			indStroke.Color = targetStroke
		end
	end

	local function apply(v, fire)
		state = v and true or false
		updateVisual(false)
		if fire then
			safeCall(action, state)
		end
	end

	updateVisual(false)
	self.Library._registry[regKey] = {
		Type = "Toggle",
		Apply = apply,
		Get = function() return state end,
		UpdateTheme = function()
			updateVisual(false)
		end,
	}

	self.Library:_track(row.MouseButton1Click:Connect(function()
		state = not state
		updateVisual(true)
		safeCall(action, state)
	end))

	table.insert(self.Elements, {
		Name = text,
		Instance = row,
		UpdateTheme = function() updateVisual(false) end,
	})

	return {
		Set = function(v) apply(v, false) end,
		Get = function() return state end,
	}
end

function TabClass:AddSlider(text, min, max, default, callback, key)
	local action = callback or function() end
	local regKey = key or self.Library:_key(text)
	local value = math.clamp(tonumber(default) or min, min, max)

	local row = new("Frame", {
		Size = UDim2.new(1, -4, 0, 45),
		BackgroundColor3 = Color3.fromRGB(26, 26, 33),
		BorderSizePixel = 0,
		Parent = self.ScrollBox,
	})
	corner(row, 6)
	stroke(row, Color3.fromRGB(35, 35, 45), 1)

	local label = new("TextLabel", {
		Size = UDim2.new(0, 200, 0, 20),
		Position = UDim2.new(0, 12, 0, 4),
		BackgroundTransparency = 1,
		Text = text,
		TextColor3 = Color3.fromRGB(215, 215, 225),
		TextSize = 12,
		Font = Enum.Font.GothamMedium,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = row,
	})

	local valLabel = new("TextLabel", {
		Size = UDim2.new(0, 60, 0, 20),
		Position = UDim2.new(1, -72, 0, 4),
		BackgroundTransparency = 1,
		Text = tostring(value),
		TextColor3 = self.Library.AccentColor,
		TextSize = 12,
		Font = Enum.Font.GothamBold,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = row,
	})

	local track = new("Frame", {
		Size = UDim2.new(1, -24, 0, 6),
		Position = UDim2.new(0, 12, 0, 28),
		BackgroundColor3 = Color3.fromRGB(40, 40, 50),
		BorderSizePixel = 0,
		Parent = row,
	})
	corner(track, 3)

	local fill = new("Frame", {
		Size = UDim2.new((max == min) and 1 or ((value - min) / (max - min)), 0, 1, 0),
		BackgroundColor3 = self.Library.AccentColor,
		BorderSizePixel = 0,
		Parent = track,
	})
	corner(fill, 3)

	local dragging = false

	local function updateSlider()
		if track.AbsoluteSize.X <= 0 then return end
		local mouseX = math.clamp(getMouseXY() - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
		local ratio = mouseX / track.AbsoluteSize.X
		value = math.floor(min + (max - min) * ratio)
		valLabel.Text = tostring(value)
		fill.Size = UDim2.new(ratio, 0, 1, 0)
		safeCall(action, value)
	end

	self.Library:_track(row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			updateSlider()
		end
	end))
	self.Library:_track(UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			updateSlider()
		end
	end))
	self.Library:_track(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
		end
	end))

	local function apply(v, fire)
		value = math.clamp(tonumber(v) or min, min, max)
		local ratio = (max == min) and 1 or ((value - min) / (max - min))
		valLabel.Text = tostring(value)
		fill.Size = UDim2.new(ratio, 0, 1, 0)
		if fire then safeCall(action, value) end
	end

	self.Library._registry[regKey] = {
		Type = "Slider",
		Apply = apply,
		Get = function() return value end,
		UpdateTheme = function()
			valLabel.TextColor3 = self.Library.AccentColor
			fill.BackgroundColor3 = self.Library.AccentColor
		end,
	}

	table.insert(self.Elements, {
		Name = text,
		Instance = row,
		UpdateTheme = function()
			valLabel.TextColor3 = self.Library.AccentColor
			fill.BackgroundColor3 = self.Library.AccentColor
		end,
	})

	return {
		Set = function(v) apply(v, false) end,
		Get = function() return value end,
	}
end

