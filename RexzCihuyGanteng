local function MinimizeWindow()  
    if self.Hidden then return end  
    self.Minimized = not self.Minimized  
    
    -- 1. Tentukan ukuran target MainFrame (Tetap Menggunakan Lebar 480)
    local targetSize = self.Minimized and UDim2.new(0, 480, 0, 38) or UDim2.new(0, 480, 0, 300)  
    TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = targetSize }):Play()  
    
    -- 2. Atur visibilitas komponen utama berdasarkan status minimize
    local visibility = not self.Minimized
    
    self.Sidebar.Visible = visibility
    self.SearchFrame.Visible = visibility
    self.ContentHolder.Visible = visibility
    
    -- 3. Sembunyikan semua Tab Pinned (seperti Settings) agar tidak mengambang/bocor
    for _, child in ipairs(MainFrame:GetChildren()) do
        if child:IsA("TextButton") and child.Name:match("_TabBtn$") then
            child.Visible = visibility
        end
    end
end  

local function ToggleHideWindow()
    self.Hidden = not self.Hidden
    if self.Hidden then
        local tw = TweenService:Create(MainFrame,
            TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { BackgroundTransparency = 1 })
        tw:Play()
        tw.Completed:Once(function() MainFrame.Visible = false end)
    else
        MainFrame.Visible = true
        MainFrame.BackgroundTransparency = 1
        
        -- SINKRONISASI DISINI: Sesuaikan target ukuran dengan basis lebar 480
        local target = self.Minimized
            and UDim2.new(0, 480, 0, 38)
            or  UDim2.new(0, 480, 0, 300)
            
        TweenService:Create(MainFrame,
            TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
            { Size = target, BackgroundTransparency = 0 }):Play()
    end
end

