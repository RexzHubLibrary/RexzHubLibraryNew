    local DragStart = nil
    local StartPos = nil
    
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            IsDragging = true
            DragStart = input.Position
            StartPos = MainFrame.Position
        end
    end)
    
    TitleBar.InputEnded:Connect(function()
        IsDragging = false
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if IsDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - DragStart
            MainFrame.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + delta.X, StartPos.Y.Scale, StartPos.Y.Offset + delta.Y)
        end
    end)
    
    -- Resizing Logic
    ResizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            IsResizing = true
            DragStart = input.Position
            StartPos = MainFrame.Size
        end
    end)
    
    ResizeHandle.InputEnded:Connect(function()
        IsResizing = false
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if IsResizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - DragStart
            local newWidth = math.clamp(StartPos.X.Offset + delta.X, Config.MinWidth, Config.MaxWidth)
            local newHeight = math.clamp(StartPos.Y.Offset + delta.Y, Config.MinHeight, Config.MaxHeight)
            MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
        end
    end)
    
    -- Button Actions
    MinBtn.MouseButton1Click:Connect(function()
        WindowMinimized = not WindowMinimized
        if WindowMinimized then
            Tween(MainFrame, {Size = UDim2.new(0, Config.DefaultWidth, 0, 52)}, 0.3)
        else
            Tween(MainFrame, {Size = UDim2.new(0, Config.DefaultWidth, 0, Config.DefaultHeight)}, 0.3)
        end
    end)
    
    CloseBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = false
        ScreenGui:Destroy()
    end)
    
    -- Update Canvas Function
    local function UpdateCanvas()
        local contentHeight = ContentList.AbsoluteContentSize.Y
        ContentScroll.CanvasSize = UDim2.new(0, 0, 0, contentHeight + 20)
    end
    
    ContentList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvas)
    UpdateCanvas()
    
    return {
        MainFrame = MainFrame,
        SidebarScroll = SidebarScroll,
        SidebarList = SidebarList,
        ContentScroll = ContentScroll,
        ContentList = ContentList,
        TitleText = TitleText,
        CurrentContent = nil,
        CurrentSection = nil
    }
end

-- Tab Class
local Tab = {}
