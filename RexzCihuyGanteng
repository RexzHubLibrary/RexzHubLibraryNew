local function FormatIcon(iconInput)
    if not iconInput then return nil end
    local iconStr = tostring(iconInput)
    
    if RexzIcons[iconStr] then
        return RexzIcons[iconStr]
    end
    if string.match(iconStr, "^%d+$") then
        return "rbxassetid://" .. iconStr
    end
    return iconStr
end

