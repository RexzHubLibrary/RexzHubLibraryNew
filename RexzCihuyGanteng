-- KATALOG TEMPLATE ICON (Tinggal panggil namanya, otomatis convert ke ID)
RexzLibrary.Icons = {
    ["Sword"]      = 10723344432, -- Icon Pedang (Combat/PVP)
    ["Crown"]      = 10734950309, -- Icon Mahkota (Premium/Main)
    ["Farm"]       = 10747372931, -- Icon Sabit/Gandum (Auto Farm)
    ["Teleport"]   = 10723374244, -- Icon Kompas/Peta (Teleport)
    ["Settings"]   = 10734963250, -- Icon Roda Gigi (Pengaturan)
    ["Stats"]      = 10747361223, -- Icon Grafik (Status/Stats)
    ["Shop"]       = 10747384912, -- Icon Keranjang (Shop/Store)
    ["Home"]       = 10723351943, -- Icon Rumah (Main Menu)
    ["Misc"]       = 10734971021  -- Icon Titik Tiga (Lain-lain)
}

-- Fungsi internal untuk cek apakah input itu Nama Icon atau ID angka asli
local function getIconId(input)
    if type(input) == "string" and RexzLibrary.Icons[input] then
        return "rbxassetid://" .. tostring(RexzLibrary.Icons[input])
    elseif type(input) == "number" then
        return "rbxassetid://" .. tostring(input)
    elseif type(input) == "string" and input:match("^%d+$") then
        return "rbxassetid://" .. input
    end
    return "rbxassetid://10723351943" -- Default Home Icon jika kosong
end

-- [ CORE LIBRARY METHODS ]
function RexzLibrary.new(hubName, subTitle)
    local self = setmetatable({}, RexzLibrary)
    
    -- Membuat ScreenGui Utama
    local CoreGui = game:GetService("CoreGui")
    if CoreGui:FindFirstChild("RexzUiMobile") then
        CoreGui.RexzUiMobile:Destroy()
    end
    
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "RexzUiMobile"
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = CoreGui
    
    -- Main Frame (Ukuran disesuaikan agar proporsional di HP)
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 480, 0, 280) -- Pas untuk resolusi HP landscape
    MainFrame.Position = UDim2.new(0.5, -240, 0.5, -140)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    MainFrame.BorderSizePixel = 0
    MainFrame.Active = true
    MainFrame.Draggable = true -- Biar bisa digeser pakai jempol
    MainFrame.Parent = ScreenGui
    
    -- UI Corner untuk sudut melengkung halus khas Rexz
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 10)
    Corner.Parent = MainFrame
    
    -- Sidebar Container (Tempat Tab)
    local Sidebar = Instance.new("ScrollingFrame")
    Sidebar.Name = "Sidebar"
    Sidebar.Size = UDim2.new(0, 140, 1, -40)
    Sidebar.Position = UDim2.new(0, 0, 0, 40)
    Sidebar.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    Sidebar.BorderSizePixel = 0
    Sidebar.CanvasSize = UDim2.new(0, 0, 0, 0)
    Sidebar.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Sidebar.ScrollBarThickness = 2
    Sidebar.Parent = MainFrame
    
    local SidebarLayout = Instance.new("UIListLayout")
    SidebarLayout.Padding = UDim.new(0, 6)
    SidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    SidebarLayout.Parent = Sidebar
    
    -- Container Tempat Fitur/Isi Tab
    local Container = Instance.new("Frame")
    Container.Name = "Container"
    Container.Size = UDim2.new(1, -150, 1, -50)
    Container.Position = UDim2.new(0, 145, 0, 45)
    Container.BackgroundTransparency = 1
    Container.Parent = MainFrame
    
    -- Title Bar
    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -20, 0, 35)
    Title.Position = UDim2.new(0, 15, 0, 5)
    Title.Text = hubName .. " | " .. subTitle
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextSize = 16
    Title.Font = Enum.Font.GothamBold
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.BackgroundTransparency = 1
    Title.Parent = MainFrame

    self.MainFrame = MainFrame
    self.Sidebar = Sidebar
    self.Container = Container
    return self
end

function RexzLibrary:CreateCategory(categoryName)
    -- Indikator Kategori teks kecil di sidebar HP
    local CatLabel = Instance.new("TextLabel")
    CatLabel.Size = UDim2.new(0, 120, 0, 20)
    CatLabel.Text = string.upper(categoryName)
    CatLabel.TextColor3 = Color3.fromRGB(100, 100, 110)
    CatLabel.TextSize = 10
    CatLabel.Font = Enum.Font.GothamBold
    CatLabel.BackgroundTransparency = 1
    CatLabel.Parent = self.Sidebar
    return CatLabel
end

function RexzLibrary:CreateTab(tabName, iconInput, categoryRef)
    local TabPage = Instance.new("ScrollingFrame")
    TabPage.Size = UDim2.new(1, 0, 1, 0)
    TabPage.BackgroundTransparency = 1
    TabPage.Visible = false
    TabPage.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabPage.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabPage.ScrollBarThickness = 4
    TabPage.Parent = self.Container
    
    local PageLayout = Instance.new("UIListLayout")
    PageLayout.Padding = UDim.new(0, 8)
    PageLayout.Parent = TabPage

    -- Tombol Tab di Sidebar
    local TabButton = Instance.new("TextButton")
    TabButton.Size = UDim2.new(0, 120, 0, 35) -- Tinggi 35px pas untuk jempol HP
    TabButton.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    TabButton.Text = "      " .. tabName -- Spasi untuk jarak dari Icon
    TabButton.TextColor3 = Color3.fromRGB(180, 180, 180)
    TabButton.TextSize = 12
    TabButton.Font = Enum.Font.GothamMedium
    TabButton.TextXAlignment = Enum.TextXAlignment.Left
    TabButton.Parent = self.Sidebar
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = TabButton
    
    -- Icon Tab (Otomatis mendeteksi Template nama atau ID)
    local TabIcon = Instance.new("ImageLabel")
    TabIcon.Size = UDim2.new(0, 18, 0, 18)
    TabIcon.Position = UDim2.new(0, 8, 0.5, -9)
    TabIcon.Image = getIconId(iconInput)
    TabIcon.BackgroundTransparency = 1
    TabIcon.ImageColor3 = Color3.fromRGB(200, 200, 200)
    TabIcon.Parent = TabButton

    -- Logika Ganti Tab saat di-klik
    TabButton.MouseButton1Click:Connect(function()
        for _, page in pairs(self.Container:GetChildren()) do
            if page:IsA("ScrollingFrame") then page.Visible = false end
        end
        for _, btn in pairs(self.Sidebar:GetChildren()) do
            if btn:IsA("TextButton") then 
                btn.BackgroundColor3 = Color3.fromRGB(25, 25, 30) 
                btn.TextColor3 = Color3.fromRGB(180, 180, 180)
            end
        end
        TabPage.Visible = true
        TabButton.BackgroundColor3 = Color3.fromRGB(60, 100, 250) -- Efek highlight khas Rexz Blue
        TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)

    -- Return object helper untuk isi komponen dalam tab
    local TabMethods = {}
    
    function TabMethods:AddLabel(text)
        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -10, 0, 25)
        Label.Text = text
        Label.TextColor3 = Color3.fromRGB(200, 200, 200)
        Label.TextSize = 12
        Label.Font = Enum.Font.GothamSemibold
        Label.BackgroundTransparency = 1
        Label.Parent = TabPage
    end

    function TabMethods:AddToggle(text, icon, default, callback)
        local ToggleBtn = Instance.new("TextButton")
        ToggleBtn.Size = UDim2.new(1, -10, 0, 38) -- Tinggi diperluas untuk kenyamanan touchscreen HP
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 35)
        ToggleBtn.Text = "      " .. text
        ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        ToggleBtn.TextSize = 12
        ToggleBtn.Font = Enum.Font.Gotham
        ToggleBtn.TextXAlignment = Enum.TextXAlignment.Left
        ToggleBtn.Parent = TabPage
        
        local TglCorner = Instance.new("UICorner")
        TglCorner.CornerRadius = UDim.new(0, 6)
        TglCorner.Parent = ToggleBtn

        -- Status Indicator (Kotak On/Off di kanan)
        local Indicator = Instance.new("Frame")
        Indicator.Size = UDim2.new(0, 30, 0, 16)
        Indicator.Position = UDim2.new(1, -40, 0.5, -8)
        Indicator.BackgroundColor3 = default and Color3.fromRGB(60, 100, 250) or Color3.fromRGB(50, 50, 55)
        Indicator.Parent = ToggleBtn
        
        local IndCorner = Instance.new("UICorner")
        IndCorner.CornerRadius = UDim.new(1, 0)
        IndCorner.Parent = Indicator

        local state = default
        ToggleBtn.MouseButton1Click:Connect(function()
            state = not state
            Indicator.BackgroundColor3 = state and Color3.fromRGB(60, 100, 250) or Color3.fromRGB(50, 50, 55)
            callback(state)
        end)
    end
    
    -- (Komponen lain seperti Button, Slider, dll. otomatis masuk ke TabPage ini)
    function TabMethods:AddButton(text, icon, callback)
        local Button = Instance.new("TextButton")
        Button.Size = UDim2.new(1, -10, 0, 38)
        Button.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        Button.Text = text
        Button.TextColor3 = Color3.fromRGB(255, 255, 255)
        Button.TextSize = 12
        Button.Font = Enum.Font.GothamBold
        Button.Parent = TabPage
        
        local BtnC = Instance.new("UICorner")
        BtnC.CornerRadius = UDim.new(0, 6)
        BtnC.Parent = Button
        
        Button.MouseButton1Click:Connect(callback)
    end

    function TabMethods:AddParagraph(title, desc)
        local Box = Instance.new("Frame")
        Box.Size = UDim2.new(1, -10, 0, 50)
        Box.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
        Box.Parent = TabPage
        
        local BoxC = Instance.new("UICorner")
        BoxC.CornerRadius = UDim.new(0, 6)
        BoxC.Parent = Box
        
        local Ttl = Instance.new("TextLabel")
        Ttl.Size = UDim2.new(1, -10, 0, 20)
        Ttl.Position = UDim2.new(0, 8, 0, 4)
        Ttl.Text = title
        Ttl.TextColor3 = Color3.fromRGB(255, 255, 255)
        Ttl.TextSize = 11
        Ttl.Font = Enum.Font.GothamBold
        Ttl.TextXAlignment = Enum.TextXAlignment.Left
        Ttl.BackgroundTransparency = 1
        Ttl.Parent = Box
        
        local Dsc = Instance.new("TextLabel")
        Dsc.Size = UDim2.new(1, -10, 0, 20)
        Dsc.Position = UDim2.new(0, 8, 0, 22)
        Dsc.Text = desc
        Dsc.TextColor3 = Color3.fromRGB(150, 150, 150)
        Dsc.TextSize = 10
        Dsc.Font = Enum.Font.Gotham
        Dsc.TextXAlignment = Enum.TextXAlignment.Left
        Dsc.BackgroundTransparency = 1
        Dsc.Parent = Box
    end

    return TabMethods
end

function RexzLibrary:Notify(title, text, duration)
    print("[" .. title .. "]: " .. text)
    -- Sistem Notifikasi visual opsional bisa kamu kembangkan di sini
end

return RexzLibrary
