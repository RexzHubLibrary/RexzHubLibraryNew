				Size = UDim2.new(1, -4, 0, 36),
			}):Play()
		end
	end))

	local function apply(v, fire)
		if v ~= nil then
			setSelected(v, fire)
		end
	end

	self.Library._registry[regKey] = {
		Type = "Dropdown",
		Apply = apply,
		Get = function() return selected end,
		UpdateTheme = function()
			label.Text = text .. " : <font color='#" .. self.Library.AccentColor:ToHex() .. "'>" .. tostring(selected or "...") .. "</font>"
		end,
	}

	table.insert(self.Elements, {
		Name = text,
		Instance = row,
		UpdateTheme = function()
			label.Text = text .. " : <font color='#" .. self.Library.AccentColor:ToHex() .. "'>" .. tostring(selected or "...") .. "</font>"
		end,
	})

	return {
		Set = function(v) apply(v, false) end,
		Get = function() return selected end,
	}
end

