local function getMouseXY()
	local p = UserInputService:GetMouseLocation()
	return p.X, p.Y
end

local function safeCall(fn, ...)
	if type(fn) == "function" then
		pcall(fn, ...)
	end
end

local function new(className, props)
	local obj = Instance.new(className)
	for k, v in pairs(props or {}) do
		obj[k] = v
	end
	return obj
end

local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 6)
	c.Parent = parent
	return c
end

local function stroke(parent, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color or Color3.fromRGB(40, 40, 50)
	s.Thickness = thickness or 1
	s.Parent = parent
	return s
end

local function makeScrollable(frame)
	local layout = new("UIListLayout", {
		Parent = frame,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 6),
	})
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		frame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
	end)
	return layout
end

function RexzLibrary:_track(conn)
	self._connections[#self._connections + 1] = conn
	return conn
end

function RexzLibrary:_key(text)
	return tostring(text):gsub("%W+", "_")
end

function RexzLibrary:SetAccent(color)
	self.AccentColor = color

	if self._toggleStroke then self._toggleStroke.Color = color end
	if self._toggleIcon then self._toggleIcon.ImageColor3 = color end
	if self._mainIcon then self._mainIcon.ImageColor3 = color end

	if self._titleLabel then
		local hex = color:ToHex()
		self._titleLabel.Text = self._hubName .. " <font color='#" .. hex .. "'>|</font> " .. self._windowTitle
	end

	if self.CurrentTab then
		for _, tab in ipairs(self.Tabs) do
			if tab == self.CurrentTab then
				tab.Label.TextColor3 = color
				if tab.Icon then tab.Icon.ImageColor3 = color end
			end
			for _, element in ipairs(tab.Elements) do
				if element.UpdateTheme then
					safeCall(element.UpdateTheme)
				end
			end
		end
	end

	if self.ConfigTab then
		self.ConfigTab.Label.TextColor3 = color
		self.ConfigTab.Icon.ImageColor3 = color
		for _, element in ipairs(self.ConfigTab.Elements) do
			if element.UpdateTheme then
				safeCall(element.UpdateTheme)
			end
		end
	end

	for _, entry in pairs(self._registry) do
		if entry.UpdateTheme then
			safeCall(entry.UpdateTheme)
		end
	end
end

function RexzLibrary:Notify(titleText, bodyText, duration)
