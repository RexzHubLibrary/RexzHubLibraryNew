    ToggleStroke.Parent = ToggleElement

    if parsedIcon then
        local ToggleIcon = Instance.new("ImageLabel")
        ToggleIcon.Size = UDim2.new(0, 16, 0, 16)
        ToggleIcon.Position = UDim2.new(0, 10, 0.5, -8)
        ToggleIcon.BackgroundTransparency = 1
        ToggleIcon.Image = parsedIcon
        ToggleIcon.ImageColor3 = Color3.fromRGB(210, 210, 220)
        ToggleIcon.Parent = ToggleElement
    end

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, parsedIcon and -76 or -56, 1, 0)
    Label.Position = UDim2.new(0, parsedIcon and 34 or 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(215, 215, 225)
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleElement

    local IndicatorFrame = Instance.new("Frame")
    IndicatorFrame.Size = UDim2.new(0, 24, 0, 24)
    IndicatorFrame.Position = UDim2.new(1, -36, 0.5, -12)
    IndicatorFrame.Parent = ToggleElement

    local IndicatorCorner = Instance.new("UICorner")
    IndicatorCorner.CornerRadius = UDim.new(0, 6)
    IndicatorCorner.Parent = IndicatorFrame

    local IndicatorStroke = Instance.new("UIStroke")
    IndicatorStroke.Parent = IndicatorFrame

    local RLogo = Instance.new("TextLabel")
    RLogo.Size = UDim2.new(1, 0, 1, 0)
    RLogo.BackgroundTransparency = 1
    RLogo.Text = "R"
    RLogo.Font = Enum.Font.GothamBold
    RLogo.Parent = IndicatorFrame

    local function UpdateToggleVisual(animate)
        local currentAccent = Themes[self.Library.CurrentTheme].Color
        local targetBg = state and currentAccent:Lerp(Color3.fromRGB(0, 0, 0), 0.6) or Color3.fromRGB(20, 20, 25)
        local targetAccent = state and currentAccent or Color3.fromRGB(45, 45, 55)
        local targetText = state and currentAccent or Color3.fromRGB(90, 90, 100)
        
        if animate then
            TweenService:Create(IndicatorFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = targetBg}):Play()
            TweenService:Create(IndicatorStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Color = targetAccent}):Play()
            TweenService:Create(RLogo, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = targetText}):Play()
        else
            IndicatorFrame.BackgroundColor3 = targetBg
            IndicatorStroke.Color = targetAccent
            RLogo.TextColor3 = targetText
        end
    end

    UpdateToggleVisual(false)

    ToggleElement.MouseButton1Click:Connect(function()
        state = not state
        UpdateToggleVisual(true)
        pcall(action, state)
    end)

    self.Library.ToggleRegistry[configKey] = {
        SetState = function(newState) state = newState UpdateToggleVisual(true) pcall(action, state) end,
        GetState = function() return state end
    }

    table.insert(self.Elements, {Name = text, Instance = ToggleElement, Type = "Toggle", UpdateVisual = UpdateToggleVisual})
end

