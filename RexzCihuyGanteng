	self.Library:_track(input.FocusLost:Connect(function(enterPressed)
		current = input.Text
		safeCall(action, input.Text, enterPressed)
	end))

	table.insert(self.Elements, { Name = text, Instance = row })
	return {
		Set = function(v) apply(v, false) end,
		Get = function() return current end,
	}
