local WindowData = nil

function RexzPremium:CreateWindow(title, options)
    options = options or {}
    WindowData = CreateMainWindow()
    WindowData.TitleText.Text = title or "REXZ PREMIUM"
    
    return {
        Title = WindowData.TitleText,
        Window = WindowData.MainFrame,
        
        CreateTab = function(tabName, icon)
            return Tab.New(tabName, icon or "📁", WindowData)
        end,
        
        Notification = function(title, msg, duration, icon)
            ShowNotification(title, msg, duration, icon)
        end,
        
        AntiAFK = AntiAFK,
        SaveConfig = SaveConfig,
        LoadConfig = LoadConfig,
        
        GetUIScale = function()
            return 1
        end,
        
        Destroy = function()
            ScreenGui:Destroy()
        end
    }
end

