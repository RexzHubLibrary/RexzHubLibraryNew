            Label.Text = text .. " : <font color='" .. hexColor .. "'>" .. optionName .. "</font>"
            ToggleDropdown()
            pcall(action, optionName)
        end)
    end

    table.insert(self.Elements, {Name = text, Instance = DropdownElement, Type = "Dropdown"})
end

