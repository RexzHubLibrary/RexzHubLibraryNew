            local mousePos = UserInputService:GetMouseLocation()
            local newWidth = math.max(450, mousePos.X - MainFrame.AbsolutePosition.X)
            local newHeight = math.max(300, mousePos.Y - MainFrame.AbsolutePosition.Y - 36)
            
