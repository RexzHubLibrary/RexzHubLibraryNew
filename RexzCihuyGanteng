    end)

    table.insert(self.Elements, {
        Name = text,
        Instance = ButtonElement,
        Type = "button"
    })
end

-- METHOD: ADD TOGGLE (with get/set value)
function TabClass:AddToggle(text, iconId, defaultState, callback)
    local state = defaultState or false
    local action = callback or function() end
    local theme = self.ParentTab and self.ParentTab.ParentTab and self.ParentTab.ParentTab.Themes[self.ParentTab.ParentTab.CurrentTheme] or RexzLibrary.Themes.dark
    local selfTab = self

    local ToggleElement = Instance.new("TextButton")
    ToggleElement.Name = text .. "_Toggle"
    ToggleElement.Size = UDim2.new(1, -4, 0, 38)
    ToggleElement.BackgroundColor3 = theme.card
    ToggleElement.BorderSizePixel = 0
    ToggleElement.Text = ""
    ToggleElement.AutoButtonColor = false
    ToggleElement.Parent = self.ScrollBox

    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 6)
    ToggleCorner.Parent = ToggleElement

    local ToggleStroke = Instance.new("UIStroke")
    ToggleStroke.Color = theme.border
    ToggleStroke.Thickness = 1
    ToggleStroke.Parent = ToggleElement

    if iconId then
        local ToggleIcon = Instance.new("ImageLabel")
        ToggleIcon.Name = "ToggleIcon"
        ToggleIcon.Size = UDim2.new(0, 16, 0, 16)
        ToggleIcon.Position = UDim2.new(0, 10, 0.5, -8)
        ToggleIcon.BackgroundTransparency = 1
        ToggleIcon.Image = "rbxassetid://" .. tostring(iconId)
        ToggleIcon.ImageColor3 = theme.textSec
        ToggleIcon.Parent = ToggleElement
    end

    local Label = Instance.new("TextLabel")
    Label.Name = "ToggleLabel"
    Label.Size = UDim2.new(1, iconId and -76 or -56, 1, 0)
    Label.Position = UDim2.new(0, iconId and 34 or 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = theme.text
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleElement

    local IndicatorFrame = Instance.new("Frame")
    IndicatorFrame.Name = "IndicatorFrame"
    IndicatorFrame.Size = UDim2.new(0, 24, 0, 24)
    IndicatorFrame.Position = UDim2.new(1, -36, 0.5, -12)
    IndicatorFrame.BackgroundColor3 = state and Color3.fromRGB(35, 30, 50) or Color3.fromRGB(20, 20, 25)
    IndicatorFrame.BorderSizePixel = 0
    IndicatorFrame.Parent = ToggleElement

    local IndicatorCorner = Instance.new("UICorner")
    IndicatorCorner.CornerRadius = UDim.new(0, 6)
    IndicatorCorner.Parent = IndicatorFrame

    local IndicatorStroke = Instance.new("UIStroke")
    IndicatorStroke.Color = state and theme.accent or Color3.fromRGB(45, 45, 55)
    IndicatorStroke.Thickness = 1.2
    IndicatorStroke.Parent = IndicatorFrame

    local RLogo = Instance.new("TextLabel")
    RLogo.Name = "RLogo"
    RLogo.Size = UDim2.new(1, 0, 1, 0)
    RLogo.BackgroundTransparency = 1
    RLogo.Text = "R"
    RLogo.TextColor3 = state and theme.accent or Color3.fromRGB(90, 90, 100)
    RLogo.TextSize = 14
    RLogo.Font = Enum.Font.GothamBold
    RLogo.TextXAlignment = Enum.TextXAlignment.Center
    RLogo.TextYAlignment = Enum.TextYAlignment.Center
    RLogo.Parent = IndicatorFrame

    local function UpdateToggleVisual(animate)
        local targetBg = state and Color3.fromRGB(35, 30, 50) or Color3.fromRGB(20, 20, 25)
        local targetAccent = state and theme.accent or Color3.fromRGB(45, 45, 55)
        local targetText = state and theme.accent or Color3.fromRGB(90, 90, 100)
        
        if animate then
            TweenService:Create(IndicatorFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = targetBg}):Play()
            TweenService:Create(IndicatorStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Color = targetAccent}):Play()
            TweenService:Create(RLogo, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextColor3 = targetText}):Play()
        else
            IndicatorFrame.BackgroundColor3 = targetBg
            IndicatorStroke.Color = targetAccent
            RLogo.TextColor3 = targetText
        end
    end

    UpdateToggleVisual(false)

    ToggleElement.MouseButton1Click:Connect(function()
        state = not state
        UpdateToggleVisual(true)
        pcall(action, state)
    end)

    local toggleData = {
        Name = text,
        Instance = ToggleElement,
        Type = "toggle",
        GetValue = function() return state end,
        SetValue = function(newState)
            state = newState
            UpdateToggleVisual(true)
            pcall(action, state)
        end
    }
    table.insert(self.Elements, toggleData)
    
    return toggleData
end

-- METHOD: ADD DROPDOWN
function TabClass:AddDropdown(text, options, defaultOption, callback)
    local theme = self.ParentTab and self.ParentTab.ParentTab and self.ParentTab.ParentTab.Themes[self.ParentTab.ParentTab.CurrentTheme] or RexzLibrary.Themes.dark
    local selectedValue = defaultOption or options[1]
    local dropdownOpen = false
    
    local DropdownFrame = Instance.new("Frame")
    DropdownFrame.Name = text .. "_Dropdown"
    DropdownFrame.Size = UDim2.new(1, -4, 0, 38)
    DropdownFrame.BackgroundColor3 = theme.card
    DropdownFrame.BorderSizePixel = 0
    DropdownFrame.Parent = self.ScrollBox
    
    local DropdownCorner = Instance.new("UICorner")
    DropdownCorner.CornerRadius = UDim.new(0, 6)
    DropdownCorner.Parent = DropdownFrame
    
    local DropdownStroke = Instance.new("UIStroke")
    DropdownStroke.Color = theme.border
    DropdownStroke.Thickness = 1
    DropdownStroke.Parent = DropdownFrame
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text .. ": " .. tostring(selectedValue)
    Label.TextColor3 = theme.text
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = DropdownFrame
    
    local DropdownIcon = Instance.new("TextLabel")
    DropdownIcon.Size = UDim2.new(0, 36, 1, 0)
    DropdownIcon.Position = UDim2.new(1, -36, 0, 0)
    DropdownIcon.BackgroundTransparency = 1
    DropdownIcon.Text = "▼"
    DropdownIcon.TextColor3 = theme.accent
    DropdownIcon.TextSize = 12
    DropdownIcon.Font = Enum.Font.GothamBold
    DropdownIcon.Parent = DropdownFrame
    
    local OptionsFrame = Instance.new("ScrollingFrame")
    OptionsFrame.Size = UDim2.new(1, 0, 0, 0)
    OptionsFrame.Position = UDim2.new(0, 0, 0, 38)
    OptionsFrame.BackgroundColor3 = theme.surface
    OptionsFrame.BorderSizePixel = 0
    OptionsFrame.Visible = false
    OptionsFrame.ClipsDescendants = true
    OptionsFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    OptionsFrame.ScrollBarThickness = 3
    OptionsFrame.Parent = DropdownFrame
    
    local OptionsCorner = Instance.new("UICorner")
    OptionsCorner.CornerRadius = UDim.new(0, 6)
    OptionsCorner.Parent = OptionsFrame
    
    local OptionsList = Instance.new("UIListLayout")
    OptionsList.Padding = UDim.new(0, 2)
    OptionsList.Parent = OptionsFrame
    
    local function UpdateOptionsHeight()
        local count = #options
        local height = math.min(count * 32, 150)
        OptionsFrame.Size = UDim2.new(1, 0, 0, height)
        DropdownFrame.Size = UDim2.new(1, -4, 0, 38 + height)
        OptionsFrame.CanvasSize = UDim2.new(0, 0, 0, OptionsList.AbsoluteContentSize.Y)
    end
    
    for _, option in ipairs(options) do
        local OptionBtn = Instance.new("TextButton")
        OptionBtn.Size = UDim2.new(1, -8, 0, 30)
        OptionBtn.Position = UDim2.new(0, 4, 0, 0)
        OptionBtn.BackgroundColor3 = theme.card
        OptionBtn.Text = "  " .. option
        OptionBtn.TextColor3 = theme.textSec
        OptionBtn.TextSize = 12
        OptionBtn.TextXAlignment = Enum.TextXAlignment.Left
        OptionBtn.Font = Enum.Font.Gotham
        OptionBtn.BorderSizePixel = 0
        OptionBtn.Parent = OptionsFrame
        
        local OptionCorner = Instance.new("UICorner")
        OptionCorner.CornerRadius = UDim.new(0, 4)
        OptionCorner.Parent = OptionBtn
        
        OptionBtn.MouseButton1Click:Connect(function()
            selectedValue = option
            Label.Text = text .. ": " .. tostring(selectedValue)
            dropdownOpen = false
            OptionsFrame.Visible = false
            DropdownFrame.Size = UDim2.new(1, -4, 0, 38)
            if callback then pcall(callback, selectedValue) end
        end)
    end
    
    DropdownIcon.MouseButton1Click:Connect(function()
        dropdownOpen = not dropdownOpen
        OptionsFrame.Visible = dropdownOpen
        if dropdownOpen then
            UpdateOptionsHeight()
        else
            DropdownFrame.Size = UDim2.new(1, -4, 0, 38)
        end
    end)
    
    table.insert(self.Elements, {
        Name = text,
        Instance = DropdownFrame,
        Type = "dropdown",
        GetValue = function() return selectedValue end
    })
end

return RexzLibrary
