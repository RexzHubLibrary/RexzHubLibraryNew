    Label.TextSize = 12
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleElement

    local IndicatorFrame = Instance.new("Frame")
    IndicatorFrame.Name = "IndicatorFrame"
    IndicatorFrame.Size = UDim2.new(0, 24, 0, 24)
    IndicatorFrame.Position = UDim2.new(1, -36, 0.5, -12)
    IndicatorFrame.BackgroundColor3 = state and Color3.fromRGB(35, 30, 50) or Color3.fromRGB(20, 20, 25)
    IndicatorFrame.BorderSizePixel = 0
    IndicatorFrame.Parent = ToggleElement

    local IndicatorCorner = Instance.new("UICorner")
    IndicatorCorner.CornerRadius = UDim.new(0, 6)
    IndicatorCorner.Parent = IndicatorFrame

    local IndicatorStroke = Instance.new("UIStroke")
    IndicatorStroke.Thickness = 1.2
    IndicatorStroke.Parent = IndicatorFrame

    local RLogo = Instance.new("TextLabel")
    RLogo.Name = "RLogo"
    RLogo.Size = UDim2.new(1, 0, 1, 0)
    RLogo.BackgroundTransparency = 1
    RLogo.Text = "R"
    RLogo.TextColor3 = state and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(90, 90, 100)
    RLogo.TextSize = 14
    RLogo.Font = Enum.Font.GothamBold
    RLogo.TextXAlignment = Enum.TextXAlignment.Center
    RLogo.TextYAlignment = Enum.TextYAlignment.Center
    RLogo.Parent = IndicatorFrame

    -- [FIX MULTI-THEME]: Update visual fungsi dipisah agar dipanggil saat ganti warna di Settings
    local function UpdateToggleVisual(animate)
        local targetBg = state and Color3.fromRGB(35, 30, 50) or Color3.fromRGB(20, 20, 25)
        local targetAccent = state and library.AccentColor or Color3.fromRGB(45, 45, 55)
        
        if animate then
            TweenService:Create(IndicatorFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = targetBg}):Play()
            TweenService:Create(IndicatorStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Color = targetAccent}):Play()
        else
            IndicatorFrame.BackgroundColor3 = targetBg
            IndicatorStroke.Color = targetAccent
        end
    end

    UpdateToggleVisual(false)

    ToggleElement.MouseButton1Click:Connect(function()
        state = not state
        UpdateToggleVisual(true)
        pcall(action, state)
    end)

    table.insert(self.Elements, {
        Name = text,
        Instance = ToggleElement,
        UpdateTheme = function() UpdateToggleVisual(false) end -- Callback untuk update tema eksternal
    })
end

return RexzLibrary
