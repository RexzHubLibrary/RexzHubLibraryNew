    stroke.Parent = label
    
    table.insert(self.Elements, {
        Name = text,
        Instance = label
    })
end

function TabClass:AddSeparator()
    local sep = Instance.new("Frame")
    sep.Size = UDim2.new(1, -8, 0, 2)
    sep.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    sep.BorderSizePixel = 0
    sep.Parent = self.ScrollBox
    
    table.insert(self.Elements, {
        Name = "Separator",
        Instance = sep
    })
end

return RexzLibrary
