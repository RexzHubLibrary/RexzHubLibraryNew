-- Save/Load Config
local function SaveConfig(configName, data)
    if not writefile then return false end
    local configString = HttpService:JSONEncode(data)
    writefile("RexzPremium_" .. configName .. ".json", configString)
    return true
end

local function LoadConfig(configName)
    if not isfile then return nil end
    if isfile("RexzPremium_" .. configName .. ".json") then
        local data = readfile("RexzPremium_" .. configName .. ".json")
        return HttpService:JSONDecode(data)
    end
    return nil
end

