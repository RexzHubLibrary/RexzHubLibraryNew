    NIco.BackgroundTransparency = 1
    NIco.Image = ResolveIcon(10734950309)
    NIco.ImageColor3 = self.Theme.Accent
    NIco.Parent = NotifBox

    local NTitle = Instance.new("TextLabel")
    NTitle.Size = UDim2.new(1, -42, 0, 18)
    NTitle.Position = UDim2.new(0, 36, 0, 10)
    NTitle.BackgroundTransparency = 1
    NTitle.Text = tostring(notifTitle)
    NTitle.TextColor3 = self.Theme.Text
    NTitle.TextSize = 12
    NTitle.Font = Enum.Font.GothamBold
    NTitle.TextXAlignment = Enum.TextXAlignment.Left
    NTitle.Parent = NotifBox

    local NDesc = Instance.new("TextLabel")
    NDesc.Size = UDim2.new(1, -22, 0, 20)
    NDesc.Position = UDim2.new(0, 14, 0, 30)
    NDesc.BackgroundTransparency = 1
    NDesc.Text = tostring(notifText)
    NDesc.TextColor3 = self.Theme.TextDim
    NDesc.TextSize = 11
    NDesc.Font = Enum.Font.GothamMedium
    NDesc.TextXAlignment = Enum.TextXAlignment.Left
    NDesc.TextWrapped = true
    NDesc.Parent = NotifBox

    TweenService:Create(NotifBox,
        TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        { Position = UDim2.new(0, 0, 0, 0) }):Play()

    task.delay(viewTime, function()
        if not NotifBox or not NotifBox.Parent then return end
        local tw = TweenService:Create(NotifBox,
            TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Position = UDim2.new(1, 20, 0, 0), BackgroundTransparency = 1 })
        tw:Play()
        tw.Completed:Connect(function()
            if NotifBox then NotifBox:Destroy() end
        end)
    end)
end

