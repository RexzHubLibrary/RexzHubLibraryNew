function RexzLibrary:CreateTab(name,iconId)
    local tab = setmetatable({},TabClass)

    tab.Parent = self
    tab.Elements = {}

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1,-4,0,34)
    button.BackgroundColor3 = self.Theme.Element
    button.Text = ""
    button.Parent = self.Sidebar
    tab.Button = button

    Instance.new("UICorner",button).CornerRadius = UDim.new(0,6)

    local icon = Instance.new("ImageLabel")
    icon.BackgroundTransparency = 1
    icon.Size = UDim2.new(0,16,0,16)
    icon.Position = UDim2.new(0,10,.5,-8)
    icon.Image = ResolveIcon(iconId)
    icon.ImageColor3 = self.Theme.Icon
    icon.Parent = button

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1,-40,1,0)
    label.Position = UDim2.new(0,34,0,0)
    label.Text = tostring(name)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 12
    label.TextColor3 = self.Theme.TextDim
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = button
    tab.Label = label

    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1,0,1,0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.Visible = false
    scroll.Parent = self.ContentHolder
    tab.Scroll = scroll

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0,6)
    layout.Parent = scroll

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize =
            UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 10)
    end)

    button.MouseButton1Click:Connect(function()
        for _,t in ipairs(self.Tabs) do
            t.Scroll.Visible = false
            t.Button.BackgroundColor3 = self.Theme.Element
            t.Label.TextColor3 = self.Theme.TextDim
        end

        scroll.Visible = true
        button.BackgroundColor3 = self.Theme.TabActive
        label.TextColor3 = self.Theme.Accent

        self.CurrentTab = button
    end)

    table.insert(self.Tabs,tab)

    if #self.Tabs == 1 then
        button:CaptureFocus()
        scroll.Visible = true
        button.BackgroundColor3 = self.Theme.TabActive
        label.TextColor3 = self.Theme.Accent
    end

    return tab
end

