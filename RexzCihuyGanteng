-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function RexzLibrary:RefreshSaveProfiles()
    if not self.SaveDropdown then return end
    local list = {}
    if listfiles and isfolder and isfolder(self.SaveFolder) then
        for _, file in ipairs(listfiles(self.SaveFolder)) do
            if file:sub(-5) == ".json" then
                local name = file:match("([^/%\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end
    end
    table.sort(list, function(a,b) return a:lower() < b:lower() end)
    if #list == 0 then list = { "Belum ada profile" } end
    if self.SaveDropdown.SetOptions then
        self.SaveDropdown:SetOptions(list, list[1], false)
    end
end

function RexzLibrary:SaveProfile(profileName)
    if not writefile then
        self:Notify("Gagal", "Executor tidak mendukung writefile.", 4)
        return false
    end
    EnsureFolder(self.SaveFolder)
    local safeName = SanitizeName(profileName)
    local path = self.SaveFolder .. "/" .. safeName .. ".json"
    local data = {
        Theme = {
            Background  = ColorToHex(self.Theme.Background),
            Topbar      = ColorToHex(self.Theme.Topbar),
            Sidebar     = ColorToHex(self.Theme.Sidebar),
            Element     = ColorToHex(self.Theme.Element),
            TabActive   = ColorToHex(self.Theme.TabActive),
            Accent      = ColorToHex(self.Theme.Accent),
            Text        = ColorToHex(self.Theme.Text),
            TextDim     = ColorToHex(self.Theme.TextDim),
            Icon        = ColorToHex(self.Theme.Icon),
            Stroke      = ColorToHex(self.Theme.Stroke),
            ToggleOnBg  = ColorToHex(self.Theme.ToggleOnBg),
            ToggleOffBg = ColorToHex(self.Theme.ToggleOffBg),
            DropdownBg  = ColorToHex(self.Theme.DropdownBg),
            InputBg     = ColorToHex(self.Theme.InputBg),
            LabelBg     = ColorToHex(self.Theme.LabelBg),
            Muted       = ColorToHex(self.Theme.Muted),
        },
        Toggles = self.ToggleStates or {}
    }
    pcall(writefile, path, HttpService:JSONEncode(data))
    self:Notify("Profile Disimpan", "\"" .. safeName .. "\" berhasil disimpan.", 4)
    self:RefreshSaveProfiles()
    return true
end

function RexzLibrary:DeleteProfile(profileName)
    if not delfile then
        self:Notify("Gagal", "Executor tidak mendukung delfile.", 4)
        return false
    end
    local safeName = SanitizeName(profileName)
    local path = self.SaveFolder .. "/" .. safeName .. ".json"
    if not FileExists(path) then
        self:Notify("Gagal", "Profile tidak ditemukan.", 4)
        return false
    end
    local ok = pcall(delfile, path)
    if not ok then
        self:Notify("Gagal", "File profile gagal dihapus.", 4)
        return false
    end
    self:Notify("Profile Dihapus", "\"" .. safeName .. "\" berhasil dihapus.", 4)
    self:RefreshSaveProfiles()
    return true
end

function RexzLibrary:LoadProfile(profileName)
    if not readfile then
        self:Notify("Gagal", "Executor tidak mendukung readfile.", 4)
        return false
    end
    local safeName = SanitizeName(profileName)
    local path = self.SaveFolder .. "/" .. safeName .. ".json"
    if not FileExists(path) then
        self:Notify("Gagal", "Profile tidak ditemukan.", 4)
        return false
    end
    local ok, raw = pcall(readfile, path)
    if not ok or not raw then
        self:Notify("Gagal", "File profile gagal dibaca.", 4)
        return false
    end
    local okD, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not okD or type(data) ~= "table" then
        self:Notify("Gagal", "Format profile tidak valid.", 4)
        return false
    end
    if data.Theme then
        for k, v in pairs(data.Theme) do
            self.Theme[k] = HexToColor(v, self.Theme[k])
        end
    end
    if data.Toggles and type(data.Toggles) == "table" then
        for name, value in pairs(data.Toggles) do
            local reg = self.ToggleRegistry and self.ToggleRegistry[name]
            if reg and reg.SetState then reg.SetState(value, true) end
        end
    end
    self:ApplyTheme(self.Theme)
    if self.SettingsRefs then
        if self.SettingsRefs.AccentBox     then self.SettingsRefs.AccentBox.Text     = ColorToHex(self.Theme.Accent) end
        if self.SettingsRefs.BackgroundBox then self.SettingsRefs.BackgroundBox.Text = ColorToHex(self.Theme.Background) end
    end
    self:Notify("Profile Dimuat", "\"" .. safeName .. "\" berhasil dimuat.", 4)
    return true
end

