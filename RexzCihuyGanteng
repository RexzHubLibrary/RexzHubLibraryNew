local ICON_SUPPORT_URL =
"https://raw.githubusercontent.com/RexzHubLibrary/RexzHubIconSupport/refs/heads/main/Icon"

local IconSupport = {}

pcall(function()
    IconSupport = loadstring(game:HttpGet(ICON_SUPPORT_URL))()
end)

local function ResolveIcon(icon)
    if not icon then
        return ""
    end

    if typeof(icon) == "number" then
        return "rbxassetid://" .. tostring(icon)
    end

    if typeof(icon) == "string" then
        if icon:match("^rbxassetid://") or icon:match("^http") then
            return icon
        end

        return
            IconSupport[icon]
            or IconSupport[string.upper(icon)]
            or IconSupport[icon:sub(1,1):upper() .. icon:sub(2)]
            or ""
    end

    return ""
end

local function Clamp255(n)
    return math.clamp(math.floor(tonumber(n) or 0),0,255)
end

local function ColorToHex(c)
    return string.format(
        "#%02X%02X%02X",
        Clamp255(c.R * 255),
        Clamp255(c.G * 255),
        Clamp255(c.B * 255)
    )
end

local function HexToColor(hex,fallback)
    if typeof(hex) ~= "string" then
        return fallback
    end

    hex = hex:gsub("#","")

    if #hex ~= 6 then
        return fallback
    end

    local r = tonumber(hex:sub(1,2),16)
    local g = tonumber(hex:sub(3,4),16)
    local b = tonumber(hex:sub(5,6),16)

    if not r or not g or not b then
        return fallback
    end

    return Color3.fromRGB(r,g,b)
end

local function SanitizeName(str)
    str = tostring(str or "")
    str = str:gsub("[\\/:*?\"<>|]","_")
    str = str:gsub("%s+","_")

    if str == "" then
        str = "Profile"
    end

    return str
end

local function EnsureFolder(path)
    if makefolder and not isfolder(path) then
        pcall(makefolder,path)
    end
end

local function FileExists(path)
    if isfile then
        local ok,res = pcall(isfile,path)
        return ok and res
    end

    return false
end

function RexzLibrary:Notify(title,text,duration)
    duration = duration or 3

    local holder = self.NotifHolder

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1,0,0,55)
    frame.BackgroundColor3 = self.Theme.Element
    frame.BorderSizePixel = 0
    frame.Position = UDim2.new(1,20,0,0)
    frame.Parent = holder

    Instance.new("UICorner",frame).CornerRadius = UDim.new(0,8)

    local stroke = Instance.new("UIStroke",frame)
    stroke.Color = self.Theme.Accent

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1,-20,0,18)
    titleLabel.Position = UDim2.new(0,10,0,6)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 12
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextColor3 = self.Theme.Text
    titleLabel.Text = tostring(title)
    titleLabel.Parent = frame

    local desc = Instance.new("TextLabel")
    desc.BackgroundTransparency = 1
    desc.Size = UDim2.new(1,-20,0,18)
    desc.Position = UDim2.new(0,10,0,26)
    desc.Font = Enum.Font.GothamMedium
    desc.TextSize = 11
    desc.TextWrapped = true
    desc.TextXAlignment = Enum.TextXAlignment.Left
    desc.TextColor3 = self.Theme.TextDim
    desc.Text = tostring(text)
    desc.Parent = frame

    TweenService:Create(
        frame,
        TweenInfo.new(0.25,Enum.EasingStyle.Back),
        {Position = UDim2.new(0,0,0,0)}
    ):Play()

    task.delay(duration,function()
        if frame and frame.Parent then
            local tween = TweenService:Create(
                frame,
                TweenInfo.new(0.25),
                {
                    Position = UDim2.new(1,20,0,0),
                    BackgroundTransparency = 1
                }
            )

            tween:Play()

            tween.Completed:Connect(function()
                frame:Destroy()
            end)
        end
    end)
end

function RexzLibrary:ApplyTheme(theme)
    self.Theme = theme

    self.MainFrame.BackgroundColor3 = theme.Background
    self.TopBar.BackgroundColor3 = theme.Topbar
    self.ToggleButton.BackgroundColor3 = theme.Element

    for _,tab in ipairs(self.Tabs) do
        if tab.Button == self.CurrentTab then
            tab.Button.BackgroundColor3 = theme.TabActive
            tab.Label.TextColor3 = theme.Accent
        else
            tab.Button.BackgroundColor3 = theme.Element
            tab.Label.TextColor3 = theme.TextDim
        end
    end
end

function RexzLibrary:SaveProfile(name)
    if not writefile then
        self:Notify("Error","Executor tidak support writefile",3)
        return
    end

    EnsureFolder("RexzLibrarySaves")
    EnsureFolder(self.SaveFolder)

    local path = self.SaveFolder.."/"..SanitizeName(name)..".json"

    local data = {
        Theme = {
            Background = ColorToHex(self.Theme.Background),
            Accent = ColorToHex(self.Theme.Accent)
        },
        Toggles = self.ToggleStates
    }

    writefile(path,HttpService:JSONEncode(data))

    self:Notify("Saved","Profile berhasil disimpan",3)
end

function RexzLibrary:LoadProfile(name)
    if not readfile then
        return
    end

    local path = self.SaveFolder.."/"..SanitizeName(name)..".json"

    if not FileExists(path) then
        self:Notify("Error","Profile tidak ditemukan",3)
        return
    end

    local data =
        HttpService:JSONDecode(readfile(path))

    if data.Theme then
        self.Theme.Background =
            HexToColor(
                data.Theme.Background,
                self.Theme.Background
            )

        self.Theme.Accent =
            HexToColor(
                data.Theme.Accent,
                self.Theme.Accent
            )
    end

    self:ApplyTheme(self.Theme)

    self:Notify("Loaded","Profile berhasil dimuat",3)
end

