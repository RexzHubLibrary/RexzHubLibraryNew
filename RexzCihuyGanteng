function RexzLibrary:CreateTab(tabName, iconId)
    local tab = setmetatable({}, TabClass)
    tab.Elements = {}
    tab.Library = self
    tab.IsSettings = false
    tab.Name = tabName
    
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, -8, 0, 36)
    button.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
    button.Text = ""
    button.BorderSizePixel = 0
    button.LayoutOrder = (#self.Tabs + 1)
    button.Parent = self.Sidebar
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = button
    
    local icon = nil
    if iconId then
        icon = Instance.new("ImageLabel")
        icon.Size = UDim2.new(0, 16, 0, 16)
        icon.Position = UDim2.new(0, 10, 0.5, -8)
        icon.BackgroundTransparency = 1
        icon.Image = "rbxassetid://" .. tostring(iconId)
        icon.ImageColor3 = Color3.fromRGB(150, 150, 160)
        icon.Parent = button
        tab.Icon = icon
    end
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, icon and -40 or -20, 1, 0)
    label.Position = UDim2.new(0, icon and 34 or 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = tabName
    label.TextColor3 = Color3.fromRGB(160, 160, 170)
    label.TextSize = 12
    label.Font = Enum.Font.GothamMedium
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = button
    tab.Label = label
    
    local scrollBox = Instance.new("ScrollingFrame")
    scrollBox.Name = tabName .. "_Scroll"
    scrollBox.Size = UDim2.new(1, 0, 1, 0)
    scrollBox.BackgroundTransparency = 1
    scrollBox.BorderSizePixel = 0
    scrollBox.ScrollBarThickness = 4
    scrollBox.ScrollBarImageColor3 = Color3.fromRGB(50, 50, 60)
    scrollBox.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollBox.Visible = false
    scrollBox.Parent = self.ContentHolder
    tab.ScrollBox = scrollBox
    
    local layout = Instance.new("UIListLayout")
    layout.Parent = scrollBox
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 8)
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scrollBox.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
    end)
    
    button.MouseButton1Click:Connect(function()
        self:ActivateTab(tab, button)
    end)
    
    tab.BackgroundColor = button
    table.insert(self.Tabs, tab)
    
    -- Auto-activate first tab (skip settings)
    if #self.Tabs == 1 then
        self:ActivateTab(tab, button)
    end
    
    return tab
end

function RexzLibrary:ActivateTab(tab, button)
    if self.CurrentTab == tab then return end
    
    -- Hide all normal tabs
    for _, t in ipairs(self.Tabs) do
        if t.ScrollBox then t.ScrollBox.Visible = false end
        if t.BackgroundColor then t.BackgroundColor.BackgroundColor3 = Color3.fromRGB(22, 22, 28) end
        if t.Label then t.Label.TextColor3 = Color3.fromRGB(160, 160, 170) end
        if t.Icon then t.Icon.ImageColor3 = Color3.fromRGB(150, 150, 160) end
    end
    
    -- Hide settings tab if visible
    if self.SettingsTabObject and self.SettingsTabObject.ScrollBox then
        self.SettingsTabObject.ScrollBox.Visible = false
    end
    if self.SettingsBtn then
        self.SettingsBtn.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
        self.SettingsLabel.TextColor3 = Color3.fromRGB(160, 160, 170)
        self.SettingsIcon.ImageColor3 = Color3.fromRGB(150, 150, 160)
    end
    
    -- Activate selected tab
    tab.ScrollBox.Visible = true
    button.BackgroundColor3 = Color3.fromRGB(32, 30, 42)
    tab.Label.TextColor3 = self.AccentColor
    if tab.Icon then tab.Icon.ImageColor3 = self.AccentColor end
    self.CurrentTab = tab
    
    -- Clear search
    if self.SearchInput then
        self.SearchInput.Text = ""
    end
end

