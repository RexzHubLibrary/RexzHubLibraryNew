-- METHOD: LIVE PRESET THEME UPDATER (Sekaligus Memperbarui Warna Footer Terkunci)
function RexzLibrary:SetTheme(index)
    self.CurrentTheme = index
    local theme = Themes[index]
    if not theme then return end
    local color = theme.Color
    
    if self.MainFrame then
        local stroke = self.MainFrame:FindFirstChildOfClass("UIStroke")
        if stroke then stroke.Color = color end
        
        -- Mengubah Warna Aksen RichText pada Footer Terkunci Secara Otomatis
        local footer = self.MainFrame:FindFirstChild("SidebarFooter")
        if footer then
            local footerText = footer:FindFirstChild("FooterText")
            if footerText then
                footerText.Text = "REXZ HUB <font color='" .. ToHex(color) .. "'>V29</font>"
            end
        end
    end
    
    if self.ScreenGui then
        local toggleBtn = self.ScreenGui:FindFirstChild("UiToggleBtn")
        if toggleBtn then
            local stroke = toggleBtn:FindFirstChildOfClass("UIStroke")
            if stroke then stroke.Color = color end
            local icon = toggleBtn:FindFirstChild("ToggleIcon")
            if icon then icon.ImageColor3 = color end
        end
    end
    
    for _, t in ipairs(self.Tabs) do
        if self.CurrentTab == t then
            t.Label.TextColor3 = color
            if t.Icon then t.Icon.ImageColor3 = color end
        else
            t.Label.TextColor3 = Color3.fromRGB(160, 160, 170)
            if t.Icon then t.Icon.ImageColor3 = Color3.fromRGB(150, 150, 160) end
        end
        
        for _, el in ipairs(t.Elements) do
            if el.Type == "Toggle" then
                el.UpdateVisual(false)
            end
        end
    end
end

-- METHOD: MULTI SAVE - SIMPAN KE JSON FILE
function RexzLibrary:SaveConfig(slot)
    if not writefile then 
        self:Notify("Error", "Eksekutor kamu tidak mendukung penyimpanan file!", 3)
        return 
    end
    local configData = {}
    for key, toggle in pairs(self.ToggleRegistry) do
        configData[key] = toggle.GetState()
    end
    configData["__RexzThemeIndex"] = self.CurrentTheme

    local success, err = pcall(function()
        writefile("RexzHub_Config_Slot" .. slot .. ".json", game:GetService("HttpService"):JSONEncode(configData))
    end)
    if success then
        self:Notify("Multi Save", "Konfigurasi disimpan sukses di Slot " .. slot, 3)
    else
        self:Notify("Error Save", "Gagal menyimpan: " .. tostring(err), 3)
    end
end

-- METHOD: MULTI SAVE - MUAT DARI JSON FILE
function RexzLibrary:LoadConfig(slot)
    if not readfile or not isfile then 
        self:Notify("Error", "Eksekutor kamu tidak mendukung pembacaan file!", 3)
        return 
    end
    local filename = "RexzHub_Config_Slot" .. slot .. ".json"
    if not isfile(filename) then
        self:Notify("Multi Save", "File konfigurasi Slot " .. slot .. " tidak ditemukan!", 3)
        return
    end

    local success, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(readfile(filename))
    end)
    
    if success and type(data) == "table" then
        for key, state in pairs(data) do
            if self.ToggleRegistry[key] then
                self.ToggleRegistry[key].SetState(state)
            end
        end
        if data["__RexzThemeIndex"] then
            self:SetTheme(data["__RexzThemeIndex"])
        end
        self:Notify("Multi Save", "Berhasil menerapkan konfigurasi Slot " .. slot, 3)
    else
        self:Notify("Error Load", "Gagal memuat file konfigurasi!", 3)
    end
end

