    local TrackBg = Instance.new("Frame")
    TrackBg.Size = UDim2.new(1, -20, 0, 10)
    TrackBg.Position = UDim2.new(0, 10, 0, 30)
    TrackBg.BackgroundColor3 = lib.Theme.ToggleOffBg
    TrackBg.BorderSizePixel = 0
    TrackBg.Parent = El
    Corner(TrackBg, 5)

    local Fill = Instance.new("Frame")
    Fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    Fill.BackgroundColor3 = lib.Theme.Accent
    Fill.BorderSizePixel = 0
    Fill.Parent = TrackBg
    Corner(Fill, 5)

    local SliderBtn = Instance.new("TextButton")
    SliderBtn.Size = UDim2.new(1, 0, 1, 20)
    SliderBtn.Position = UDim2.new(0, 0, 0, -10)
    SliderBtn.BackgroundTransparency = 1
    SliderBtn.Text = ""
    SliderBtn.AutoButtonColor = false
    SliderBtn.ZIndex = 5
    SliderBtn.Parent = TrackBg

    local dragging = false

    local function UpdateFromX(x)
        local abs = TrackBg.AbsolutePosition.X
        local sz  = TrackBg.AbsoluteSize.X
        if sz <= 0 then return end
        local pct = math.clamp((x - abs) / sz, 0, 1)
        value = math.floor(min + (max - min) * pct + 0.5)
        Fill.Size = UDim2.new(pct, 0, 1, 0)
        ValLabel.Text = tostring(value)
        pcall(action, value)
    end

    SliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            UpdateFromX(input.Position.X)
        end
    end)

    SliderBtn.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateFromX(input.Position.X)
        end
    end)

    SliderBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
            UpdateFromX(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        GetValue = function() return value end,
        SetValue = function(v)
            value = math.clamp(v, min, max)
            Fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
            ValLabel.Text = tostring(value)
        end
    }
end

function TabClass:AddTextbox(text, iconId, placeholder, callback)
    return self:AddInput(text, iconId, placeholder, callback)
end

function TabClass:AddDropdown(text, iconId, options, defaultValue, callback)
    local lib      = self.Library
    local action   = callback or function() end
    local open     = false
    local listOpts = options or {}
    local selected = defaultValue or (listOpts[1] or "None")

    local Root = Instance.new("TextButton")
    Root.Name = text .. "_Dropdown"
    Root.Size = UDim2.new(1, -4, 0, 38)
    Root.BackgroundColor3 = lib.Theme.DropdownBg
    Root.BorderSizePixel = 0
    Root.ClipsDescendants = true
    Root.Text = ""
    Root.AutoButtonColor = false
    Root.Parent = self.ScrollBox
    Corner(Root, 6)
    Stroke(Root, lib.Theme.Stroke, 1)

    local Icon = nil
    if iconId then
        Icon = Instance.new("ImageLabel")
        Icon.Name = "DropdownIcon"
        Icon.Size = UDim2.new(0, 14, 0, 14)
        Icon.Position = UDim2.new(0, 10, 0, 12)
        Icon.BackgroundTransparency = 1
        Icon.Image = ResolveIcon(iconId)
        Icon.ImageColor3 = lib.Theme.Icon
        Icon.Parent = Root
    end

    local Label = Instance.new("TextLabel")
    Label.Name = "DropdownLabel"
    Label.Size = UDim2.new(1, iconId and -108 or -88, 0, 16)
    Label.Position = UDim2.new(0, iconId and 30 or 10, 0, 4)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = lib.Theme.Text
    Label.TextSize = 11
    Label.Font = Enum.Font.GothamBold
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Root

    local ValLabel = Instance.new("TextLabel")
    ValLabel.Name = "ValueLabel"
    ValLabel.Size = UDim2.new(1, iconId and -108 or -88, 0, 14)
    ValLabel.Position = UDim2.new(0, iconId and 30 or 10, 0, 19)
    ValLabel.BackgroundTransparency = 1
    ValLabel.Text = tostring(selected)
    ValLabel.TextColor3 = lib.Theme.TextDim
    ValLabel.TextSize = 10
    ValLabel.Font = Enum.Font.GothamMedium
    ValLabel.TextXAlignment = Enum.TextXAlignment.Left
    ValLabel.Parent = Root

    local Arrow = Instance.new("TextLabel")
    Arrow.Name = "Arrow"
    Arrow.Size = UDim2.new(0, 18, 0, 18)
    Arrow.Position = UDim2.new(1, -24, 0, 10)
    Arrow.BackgroundTransparency = 1
    Arrow.Text = "v"
    Arrow.TextColor3 = lib.Theme.Muted
    Arrow.TextSize = 10
    Arrow.Font = Enum.Font.GothamBold
    Arrow.TextXAlignment = Enum.TextXAlignment.Center
    Arrow.Parent = Root

    local OptionHolder = Instance.new("Frame")
    OptionHolder.Size = UDim2.new(1, 0, 0, 0)
    OptionHolder.Position = UDim2.new(0, 0, 0, 38)
    OptionHolder.BackgroundTransparency = 1
    OptionHolder.ClipsDescendants = true
    OptionHolder.Parent = Root

    local OptionScroll = Instance.new("ScrollingFrame")
    OptionScroll.Size = UDim2.new(1, 0, 1, 0)
    OptionScroll.BackgroundTransparency = 1
    OptionScroll.BorderSizePixel = 0
    OptionScroll.ScrollBarThickness = 2
    OptionScroll.ScrollBarImageColor3 = lib.Theme.Stroke
    OptionScroll.CanvasSize = UDim2.new(0,0,0,0)
    OptionScroll.Parent = OptionHolder

    local OptLayout = Instance.new("UIListLayout")
    OptLayout.SortOrder = Enum.SortOrder.LayoutOrder
    OptLayout.Padding = UDim.new(0, 3)
    OptLayout.Parent = OptionScroll

    local function setValue(v, fire)
        selected = tostring(v)
        ValLabel.Text = selected
        if fire then pcall(action, selected) end
    end

    local function rebuild()
        for _, c in ipairs(OptionScroll:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        for i, opt in ipairs(listOpts) do
            local Btn = Instance.new("TextButton")
            Btn.Name = "Opt_" .. i
            Btn.Size = UDim2.new(1, -6, 0, 26)
            Btn.BackgroundColor3 = lib.Theme.Element
            Btn.Text = ""
            Btn.BorderSizePixel = 0
            Btn.Parent = OptionScroll
            Corner(Btn, 5)
            Stroke(Btn, lib.Theme.Stroke, 1)

            local T = Instance.new("TextLabel")
            T.Size = UDim2.new(1, -14, 1, 0)
            T.Position = UDim2.new(0, 8, 0, 0)
            T.BackgroundTransparency = 1
            T.Text = tostring(opt)
            T.TextColor3 = lib.Theme.Text
            T.TextSize = 11
            T.Font = Enum.Font.GothamMedium
            T.TextXAlignment = Enum.TextXAlignment.Left
            T.Parent = Btn

            Btn.MouseEnter:Connect(function() TweenService:Create(Btn, TweenInfo.new(0.1), { BackgroundColor3 = lib.Theme.TabActive }):Play() end)
            Btn.MouseLeave:Connect(function() TweenService:Create(Btn, TweenInfo.new(0.1), { BackgroundColor3 = lib.Theme.Element }):Play() end)
            Btn.MouseButton1Click:Connect(function()
                setValue(opt, true)
                open = false
                TweenService:Create(Root, TweenInfo.new(0.15), { Size = UDim2.new(1,-4,0,38) }):Play()
                OptionHolder.Size = UDim2.new(1,0,0,0)
                Arrow.Text = "v"
            end)
        end
        OptionScroll.CanvasSize = UDim2.new(0, 0, 0, OptLayout.AbsoluteContentSize.Y + 4)
    end

    Root.MouseButton1Click:Connect(function()
        open = not open
        if open then
            rebuild()
            local h = math.clamp(OptLayout.AbsoluteContentSize.Y + 4, 0, 110)
            OptionHolder.Size = UDim2.new(1,0,0,h)
            TweenService:Create(Root, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Size = UDim2.new(1,-4,0,38+h+4) }):Play()
            Arrow.Text = "^"
        else
            OptionHolder.Size = UDim2.new(1,0,0,0)
            TweenService:Create(Root, TweenInfo.new(0.15), { Size = UDim2.new(1,-4,0,38) }):Play()
            Arrow.Text = "v"
        end
    end)

    setValue(selected, false)

    table.insert(lib.ControlRegistry, { Kind = "Dropdown", Root = Root, Title = Label, Icon = Icon, ValueLabel = ValLabel, Arrow = Arrow })
    table.insert(self.Elements, { Name = text, Instance = Root })

    local api = {}
    function api:GetValue() return selected end
    function api:SetValue(v, fire) setValue(v, fire) end
    function api:SetOptions(newOpts, newDef, fireDef)
        listOpts = newOpts or {}
        if newDef ~= nil then setValue(newDef, fireDef) end
        if open then rebuild() end
    end
    return api
end

return RexzLibrary
