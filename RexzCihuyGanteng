			if self.Minimized or self.Hidden then return end
			local m = Vector2.new(getMouseXY())
			local delta = m - dragStartPos
			local newW = math.clamp(startSize.X + delta.X, 460, 900)
			local newH = math.clamp(startSize.Y + delta.Y, 280, 650)
			self._baseSize = UDim2.new(0, newW, 0, newH)
			mainFrame.Size = self._baseSize
		end
	end))

	self:_track(UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			resizing = false
		end
	end))

	local function minimizeWindow()
		if self.Hidden then return end
		self.Minimized = not self.Minimized
		if self.Minimized then
			resizeGrip.Visible = false
			TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = UDim2.new(0, self._baseSize.X.Offset, 0, 38),
			}):Play()
		else
			resizeGrip.Visible = true
			TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = self._baseSize,
			}):Play()
		end
	end

	local function toggleHideWindow()
		self.Hidden = not self.Hidden
		if self.Hidden then
			resizeGrip.Visible = false
			local tw = TweenService:Create(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				BackgroundTransparency = 1,
			})
			tw:Play()
			tw.Completed:Connect(function()
				if mainFrame then mainFrame.Visible = false end
			end)
		else
			mainFrame.Visible = true
			local tw = TweenService:Create(mainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0,
			})
			tw:Play()
			resizeGrip.Visible = not self.Minimized
			mainFrame.Size = self.Minimized and UDim2.new(0, self._baseSize.X.Offset, 0, 38) or self._baseSize
		end
	end

	self:_track(toggleBtn.MouseButton1Click:Connect(toggleHideWindow))
	self:_track(UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode == self.ToggleKey then
