local function FormatIcon(iconInput)
    if not iconInput then return nil end
    local iconStr = tostring(iconInput)
    return RexzIcons[iconStr] or (string.match(iconStr, "^%d+$") and "rbxassetid://" .. iconStr) or iconStr
end

