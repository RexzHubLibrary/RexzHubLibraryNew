    valueLabel.Parent = sliderFrame
    
    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -24, 0, 4)
    track.Position = UDim2.new(0, 12, 0, 42)
    track.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    track.BorderSizePixel = 0
    track.Parent = sliderFrame
    
    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(0, 2)
    trackCorner.Parent = track
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = library.AccentColor
    fill.BorderSizePixel = 0
    fill.Parent = track
    
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 2)
    fillCorner.Parent = fill
    
    local dragBtn = Instance.new("TextButton")
    dragBtn.Size = UDim2.new(0, 14, 0, 14)
    dragBtn.Position = UDim2.new((value - min) / (max - min), -7, 0.5, -7)
    dragBtn.BackgroundColor3 = library.AccentColor
    dragBtn.Text = ""
    dragBtn.Parent = track
    
    local dragCorner = Instance.new("UICorner")
    dragCorner.CornerRadius = UDim.new(0, 7)
    dragCorner.Parent = dragBtn
    
    local dragging = false
    
    local function updateValue(newVal)
        value = math.clamp(newVal, min, max)
        local percent = (value - min) / (max - min)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        dragBtn.Position = UDim2.new(percent, -7, 0.5, -7)
        valueLabel.Text = tostring(value)
        label.Text = string.format("%s: %d", text, value)
        pcall(action, value)
    end
    
    dragBtn.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local trackPos = track.AbsolutePosition.X
            local trackSize = track.AbsoluteSize.X
            local mouseX = math.clamp(Mouse.X - trackPos, 0, trackSize)
            local percent = mouseX / trackSize
            local newValue = min + (max - min) * percent
            updateValue(math.floor(newValue + 0.5))
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    table.insert(self.Elements, {
        Name = text,
        Instance = sliderFrame,
        UpdateTheme = function()
            fill.BackgroundColor3 = library.AccentColor
            dragBtn.BackgroundColor3 = library.AccentColor
            valueLabel.TextColor3 = library.AccentColor
        end
    })
end

