    IndicatorFrame.Size = UDim2.new(0, 24, 0, 24)  
    IndicatorFrame.Position = UDim2.new(1, -36, 0.5, -12)  
    IndicatorFrame.BackgroundColor3 = state and lib.Theme.ToggleOnBg or lib.Theme.ToggleOffBg  
    IndicatorFrame.BorderSizePixel = 0  
    IndicatorFrame.Parent = ToggleElement  

    local IndicatorCorner = Instance.new("UICorner")  
    IndicatorCorner.CornerRadius = UDim.new(0, 6)  
    IndicatorCorner.Parent = IndicatorFrame  

    local IndicatorStroke = Instance.new("UIStroke")  
    IndicatorStroke.Color = state and lib.Theme.Accent or lib.Theme.Stroke  
    IndicatorStroke.Thickness = 1.2  
    IndicatorStroke.Parent = IndicatorFrame  

    local RLogo = Instance.new("TextLabel")  
    RLogo.Name = "RLogo"  
    RLogo.Size = UDim2.new(1, 0, 1, 0)  
    RLogo.BackgroundTransparency = 1  
    RLogo.Text = "R"  
    RLogo.TextColor3 = state and lib.Theme.Accent or lib.Theme.Muted  
    RLogo.TextSize = 14  
    RLogo.Font = Enum.Font.GothamBold  
    RLogo.TextXAlignment = Enum.TextXAlignment.Center  
    RLogo.TextYAlignment = Enum.TextYAlignment.Center  
    RLogo.Parent = IndicatorFrame  

    local function UpdateToggleVisual(animate)  
        local targetBg = state and lib.Theme.ToggleOnBg or lib.Theme.ToggleOffBg  
        local targetAccent = state and lib.Theme.Accent or lib.Theme.Stroke  
        local targetText = state and lib.Theme.Accent or lib.Theme.Muted  

        if animate then  
            TweenService:Create(IndicatorFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundColor3 = targetBg }):Play()  
            TweenService:Create(IndicatorStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Color = targetAccent }):Play()  
            TweenService:Create(RLogo, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextColor3 = targetText }):Play()  
        else  
            IndicatorFrame.BackgroundColor3 = targetBg  
            IndicatorStroke.Color = targetAccent  
            RLogo.TextColor3 = targetText  
        end  
    end  

    UpdateToggleVisual(false)  

    ToggleElement.MouseButton1Click:Connect(function()  
        state = not state  
        lib.ToggleStates[text] = state  
        UpdateToggleVisual(true)  
        pcall(action, state)  
    end)  

    lib.ToggleStates[text] = state  
    lib.ToggleRegistry[text] = {  
        SetState = function(newState, fire)  
            state = newState and true or false  
            lib.ToggleStates[text] = state  
            UpdateToggleVisual(true)  
            if fire then pcall(action, state) end  
        end  
    }  

    table.insert(lib.ControlRegistry, {  
        Kind = "Toggle",  
        Root = ToggleElement,  
        Title = Label,  
        Icon = ToggleIcon,  
        Text = Label,  
        Indicator = IndicatorFrame,  
        RLogo = RLogo,  
        State = state  
    })  

    table.insert(self.Elements, { Name = text, Instance = ToggleElement })
end

function TabClass:AddInput(text, iconId, placeholder, callback)
    local lib = self.Library
    local action = callback or function() end
    local currentValue = placeholder or ""

    local InputElement = Instance.new("Frame")  
    InputElement.Name = text .. "_Input"  
    InputElement.Size = UDim2.new(1, -4, 0, 40)  
    InputElement.BackgroundColor3 = lib.Theme.InputBg  
    InputElement.BorderSizePixel = 0  
    InputElement.Parent = self.ScrollBox  

    local Corner = Instance.new("UICorner")  
    Corner.CornerRadius = UDim.new(0, 6)  
    Corner.Parent = InputElement  

    local Stroke = Instance.new("UIStroke")  
    Stroke.Color = lib.Theme.Stroke  
    Stroke.Thickness = 1  
    Stroke.Parent = InputElement  

    local IconSpec = nil  
    if iconId then  
        IconSpec = Instance.new("ImageLabel")  
        IconSpec.Name = "InputIcon"  
        IconSpec.Size = UDim2.new(0, 16, 0, 16)  
        IconSpec.Position = UDim2.new(0, 10, 0.5, -8)  
        IconSpec.BackgroundTransparency = 1  
        IconSpec.Image = ResolveIcon(iconId)  
        IconSpec.ImageColor3 = lib.Theme.Icon  
        IconSpec.Parent = InputElement  
    end  

    local Label = Instance.new("TextLabel")  
    Label.Name = "InputLabel"  
    Label.Size = UDim2.new(1, iconId and -80 or -60, 0, 16)  
    Label.Position = UDim2.new(0, iconId and 34 or 12, 0, 6)  
    Label.BackgroundTransparency = 1  
    Label.Text = text  
    Label.TextColor3 = lib.Theme.Text  
    Label.TextSize = 11  
    Label.Font = Enum.Font.GothamBold  
    Label.TextXAlignment = Enum.TextXAlignment.Left  
    Label.Parent = InputElement  

    local Box = Instance.new("TextBox")  
    Box.Name = "InputBox"  
    Box.Size = UDim2.new(1, -24, 0, 16)  
    Box.Position = UDim2.new(0, 12, 0, 20)  
    Box.BackgroundTransparency = 1  
    Box.Text = placeholder or ""  
    Box.PlaceholderText = placeholder or ""  
    Box.PlaceholderColor3 = lib.Theme.Muted  
    Box.TextColor3 = lib.Theme.Text  
    Box.TextSize = 11  
    Box.Font = Enum.Font.GothamMedium  
    Box.TextXAlignment = Enum.TextXAlignment.Left  
    Box.ClearTextOnFocus = false  
    Box.Parent = InputElement  

    if iconId then  
        Box.Position = UDim2.new(0, 34, 0, 20)  
        Box.Size = UDim2.new(1, -46, 0, 16)  
    end  

    Box.FocusLost:Connect(function(enterPressed)  
        currentValue = Box.Text  
        pcall(action, currentValue, enterPressed)  
    end)  

    local ref = {  
        Kind = "Input",  
        Root = InputElement,  
        Title = Label,  
        Icon = IconSpec,  
        Box = Box  
    }  

    table.insert(lib.ControlRegistry, ref)  
    table.insert(self.Elements, { Name = text, Instance = InputElement })  

    return {  
        Box = Box,  
        GetValue = function() return Box.Text end,  
        SetValue = function(v)  
            Box.Text = tostring(v or "")  
            currentValue = Box.Text  
        end  
    }
end

function TabClass:AddDropdown(text, iconId, options, defaultValue, callback)
    local lib = self.Library
    local action = callback or function() end
    local open = false
    local listOptions = options or {}
    local selected = defaultValue or (listOptions[1] or "None")

    local DropdownRoot = Instance.new("TextButton")  
    DropdownRoot.Name = text .. "_Dropdown"  
    DropdownRoot.Size = UDim2.new(1, -4, 0, 38)  
    DropdownRoot.BackgroundColor3 = lib.Theme.DropdownBg  
    DropdownRoot.BorderSizePixel = 0  
    DropdownRoot.ClipsDescendants = true  
    DropdownRoot.Text = ""  
    DropdownRoot.AutoButtonColor = false  
    DropdownRoot.Parent = self.ScrollBox  

    local Corner = Instance.new("UICorner")  
    Corner.CornerRadius = UDim.new(0, 6)  
    Corner.Parent = DropdownRoot  

    local Stroke = Instance.new("UIStroke")  
    Stroke.Color = lib.Theme.Stroke  
    Stroke.Thickness = 1  
    Stroke.Parent = DropdownRoot  

    local IconSpec = nil  
    if iconId then  
        IconSpec = Instance.new("ImageLabel")  
        IconSpec.Name = "DropdownIcon"  
        IconSpec.Size = UDim2.new(0, 16, 0, 16)  
        IconSpec.Position = UDim2.new(0, 10, 0, 11)  
        IconSpec.BackgroundTransparency = 1  
        IconSpec.Image = ResolveIcon(iconId)  
        IconSpec.ImageColor3 = lib.Theme.Icon  
        IconSpec.Parent = DropdownRoot  
    end  

    local Label = Instance.new("TextLabel")  
    Label.Name = "DropdownLabel"  
    Label.Size = UDim2.new(1, iconId and -110 or -90, 0, 16)  
    Label.Position = UDim2.new(0, iconId and 34 or 12, 0, 4)  
    Label.BackgroundTransparency = 1  
    Label.Text = text  
    Label.TextColor3 = lib.Theme.Text  
    Label.TextSize = 11  
    Label.Font = Enum.Font.GothamBold  
    Label.TextXAlignment = Enum.TextXAlignment.Left  
    Label.Parent = DropdownRoot  

    local ValueLabel = Instance.new("TextLabel")  
    ValueLabel.Name = "ValueLabel"  
    ValueLabel.Size = UDim2.new(1, iconId and -110 or -90, 0, 14)  
    ValueLabel.Position = UDim2.new(0, iconId and 34 or 12, 0, 18)  
    ValueLabel.BackgroundTransparency = 1  
    ValueLabel.Text = tostring(selected)  
    ValueLabel.TextColor3 = lib.Theme.TextDim  
    ValueLabel.TextSize = 10  
    ValueLabel.Font = Enum.Font.GothamMedium  
    ValueLabel.TextXAlignment = Enum.TextXAlignment.Left  
    ValueLabel.Parent = DropdownRoot  

    local Arrow = Instance.new("TextLabel")  
    Arrow.Name = "Arrow"  
    Arrow.Size = UDim2.new(0, 20, 0, 20)  
    Arrow.Position = UDim2.new(1, -28, 0, 9)  
    Arrow.BackgroundTransparency = 1  
    Arrow.Text = "⌄"  
    Arrow.TextColor3 = lib.Theme.Muted  
    Arrow.TextSize = 16  
    Arrow.Font = Enum.Font.GothamBold  
    Arrow.TextXAlignment = Enum.TextXAlignment.Center  
    Arrow.Parent = DropdownRoot  

    local OptionHolder = Instance.new("Frame")  
    OptionHolder.Name = "OptionsHolder"  
    OptionHolder.Size = UDim2.new(1, 0, 0, 0)  
    OptionHolder.Position = UDim2.new(0, 0, 0, 38)  
    OptionHolder.BackgroundTransparency = 1  
    OptionHolder.ClipsDescendants = true  
    OptionHolder.Parent = DropdownRoot  

    local OptionScroll = Instance.new("ScrollingFrame")  
    OptionScroll.Name = "OptionsScroll"  
    OptionScroll.Size = UDim2.new(1, 0, 1, 0)  
    OptionScroll.BackgroundTransparency = 1  
    OptionScroll.BorderSizePixel = 0  
    OptionScroll.ScrollBarThickness = 3  
    OptionScroll.ScrollBarImageColor3 = lib.Theme.Icon  
    OptionScroll.CanvasSize = UDim2.new(0, 0, 0, 0)  
    OptionScroll.Parent = OptionHolder  

    local OptionLayout = Instance.new("UIListLayout")  
    OptionLayout.Parent = OptionScroll  
    OptionLayout.SortOrder = Enum.SortOrder.LayoutOrder  
    OptionLayout.Padding = UDim.new(0, 4)  

    local function clearOptions()  
        for _, child in ipairs(OptionScroll:GetChildren()) do  
            if child:IsA("TextButton") then child:Destroy() end  
        end  
    end  

    local function setValue(v, fire)  
        selected = tostring(v)  
        ValueLabel.Text = selected  
        if fire then pcall(action, selected) end  
    end  

    local function rebuildOptions()  
        clearOptions()  
        for i, opt in ipairs(listOptions) do  
            local optBtn = Instance.new("TextButton")  
            optBtn.Name = "Option_" .. i  
            optBtn.Size = UDim2.new(1, -8, 0, 28)  
            optBtn.BackgroundColor3 = lib.Theme.Element  
            optBtn.Text = ""  
            optBtn.BorderSizePixel = 0  
            optBtn.Parent = OptionScroll  

            local c = Instance.new("UICorner")  
            c.CornerRadius = UDim.new(0, 6)  
            c.Parent = optBtn  

            local s = Instance.new("UIStroke")  
            s.Color = lib.Theme.Stroke  
            s.Thickness = 1  
            s.Parent = optBtn  

            local t = Instance.new("TextLabel")  
            t.Size = UDim2.new(1, -16, 1, 0)  
            t.Position = UDim2.new(0, 8, 0, 0)  
            t.BackgroundTransparency = 1  
            t.Text = tostring(opt)  
            t.TextColor3 = lib.Theme.Text  
            t.TextSize = 11  
            t.Font = Enum.Font.GothamMedium  
            t.TextXAlignment = Enum.TextXAlignment.Left  
            t.Parent = optBtn  

            optBtn.MouseButton1Click:Connect(function()  
                setValue(opt, true)  
                open = false  
                DropdownRoot.Size = UDim2.new(1, -4, 0, 38)  
                Arrow.Text = "⌄"  
                OptionHolder.Size = UDim2.new(1, 0, 0, 0)  
            end)  
        end  
        OptionScroll.CanvasSize = UDim2.new(0, 0, 0, OptionLayout.AbsoluteContentSize.Y + 4)  
    end  

    local function toggleDropdown()  
        open = not open  
        if open then  
            rebuildOptions()  
            local maxSpace = math.clamp(OptionLayout.AbsoluteContentSize.Y + 4, 0, 100)  
            OptionHolder.Size = UDim2.new(1, 0, 0, maxSpace)  
            TweenService:Create(DropdownRoot, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {  
                Size = UDim2.new(1, -4, 0, 38 + maxSpace + 4)  
            }):Play()  
            Arrow.Text = "⌃"  
        else  
            OptionHolder.Size = UDim2.new(1, 0, 0, 0)  
            TweenService:Create(DropdownRoot, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {  
                Size = UDim2.new(1, -4, 0, 38)  
            }):Play()  
            Arrow.Text = "⌄"  
        end  
    end  

    DropdownRoot.MouseButton1Click:Connect(toggleDropdown)  
    setValue(selected, false)  

    table.insert(lib.ControlRegistry, {  
        Kind = "Dropdown",  
        Root = DropdownRoot,  
        Title = Label,  
        Icon = IconSpec,  
        ValueLabel = ValueLabel,  
        Arrow = Arrow  
    })  

    table.insert(self.Elements, { Name = text, Instance = DropdownRoot })  

    local dropdownApi = {}  
    function dropdownApi:GetValue() return selected end  
    function dropdownApi:SetValue(v, fire) setValue(v, fire) end  
    function dropdownApi:SetOptions(newOptions, newDefault, fireDefault)  
        listOptions = newOptions or {}  
        if newDefault ~= nil then  
            setValue(newDefault, fireDefault)  
        end  
        if open then rebuildOptions() end  
    end  

    return dropdownApi
end

return RexzLibrary
