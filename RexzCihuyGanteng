-- ========== CORE FUNCTIONS ==========
function RexzLibrary:ApplyGlobalAccent(newColor)
    self.AccentColor = newColor
    
    if self.FloatingBtn and self.FloatingBtn.UIStroke then
        self.FloatingBtn.UIStroke.Color = newColor
    end
    if self.FloatingIcon then
        self.FloatingIcon.ImageColor3 = newColor
    end
    
    if self.TitleLabel then
        local hexStr = newColor:ToHex()
        local currentText = self.TitleLabel.Text
        local baseText = currentText:match("^(.-) <font") or currentText:match("^(.-) |")
        if baseText then
            self.TitleLabel.Text = string.format("%s <font color='#%s'>|</font>", baseText, hexStr)
        end
    end
    
    -- Update active tab
    for _, tab in ipairs(self.Tabs) do
        if self.CurrentTab == tab then
            if tab.Label then tab.Label.TextColor3 = newColor end
            if tab.Icon then tab.Icon.ImageColor3 = newColor end
        end
    end
    
    -- Update settings tab button if active
    if self.CurrentTab == self.SettingsTabObject then
        if self.SettingsLabel then self.SettingsLabel.TextColor3 = newColor end
        if self.SettingsIcon then self.SettingsIcon.ImageColor3 = newColor end
    end
    
    -- Update all elements that support theme update
    for _, tab in ipairs(self.Tabs) do
        for _, element in ipairs(tab.Elements) do
            if element.UpdateTheme then
                element.UpdateTheme()
            end
        end
    end
    if self.SettingsTabObject then
        for _, element in ipairs(self.SettingsTabObject.Elements) do
            if element.UpdateTheme then
                element.UpdateTheme()
            end
        end
    end
end

function RexzLibrary:ActivateSettingsTab()
    if not self.SettingsTabObject then return end
    
    -- Hide all normal tabs
    for _, tab in ipairs(self.Tabs) do
        if tab.ScrollBox then
            tab.ScrollBox.Visible = false
        end
        if tab.BackgroundColor then
            tab.BackgroundColor.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
        end
        if tab.Label then
            tab.Label.TextColor3 = Color3.fromRGB(160, 160, 170)
        end
        if tab.Icon then
            tab.Icon.ImageColor3 = Color3.fromRGB(150, 150, 160)
        end
    end
    
    -- Show settings tab
    self.SettingsTabObject.ScrollBox.Visible = true
    self.SettingsBtn.BackgroundColor3 = Color3.fromRGB(32, 30, 42)
    self.SettingsLabel.TextColor3 = self.AccentColor
    self.SettingsIcon.ImageColor3 = self.AccentColor
    self.CurrentTab = self.SettingsTabObject
    
    -- Clear search
    if self.SearchInput then
        self.SearchInput.Text = ""
    end
end

function RexzLibrary:MinimizeWindow()
    if self.Hidden then return end
    self.Minimized = not self.Minimized
    
    if self.Minimized then
        if self.ResizeGrip then self.ResizeGrip.Visible = false end
        TweenService:Create(self.MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
            Size = UDim2.new(0, self.WindowSize.X.Offset, 0, 42)
        }):Play()
    else
        if self.ResizeGrip then self.ResizeGrip.Visible = true end
        TweenService:Create(self.MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {
            Size = self.WindowSize
        }):Play()
    end
end

function RexzLibrary:HideWindow()
    self.Hidden = not self.Hidden
    
    if self.Hidden then
        if self.ResizeGrip then self.ResizeGrip.Visible = false end
        local targetSize = self.Minimized and 
            UDim2.new(0, self.WindowSize.X.Offset - 50, 0, 42) or 
            UDim2.new(0, self.WindowSize.X.Offset - 50, 0, self.WindowSize.Y.Offset - 30)
        
        local tween = TweenService:Create(self.MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
            Size = targetSize,
            BackgroundTransparency = 1
        })
        tween:Play()
        tween.Completed:Connect(function()
            self.MainFrame.Visible = false
        end)
    else
        self.MainFrame.Visible = true
        if self.ResizeGrip then self.ResizeGrip.Visible = not self.Minimized end
