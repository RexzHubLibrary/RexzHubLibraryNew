    NBar.Size = UDim2.new(0, 3, 1, -12)
    NBar.Position = UDim2.new(0, 0, 0, 6)
    NBar.BackgroundColor3 = self.Theme.Accent
    NBar.BorderSizePixel = 0
    NBar.Parent = NotifBox
    Corner(NBar, 4)

    local NIco = Instance.new("ImageLabel")
    NIco.Size = UDim2.new(0, 16, 0, 16)
