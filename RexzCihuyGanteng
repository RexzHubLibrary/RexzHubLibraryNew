        tabButton.Position = UDim2.new(0, 5, 0, (#window.Tabs * 40) + 10)
        tabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
        tabButton.BackgroundTransparency = 0.5
        tabButton.Text = tabName
        tabButton.TextColor3 = Color3.fromRGB(200, 200, 200)
        tabButton.TextSize = 14
        tabButton.Font = Enum.Font.Gotham
        tabButton.BorderSizePixel = 0
        tabButton.Parent = TabContainer
        
        local tabCorner = Instance.new("UICorner")
        tabCorner.CornerRadius = UDim.new(0, 4)
        tabCorner.Parent = tabButton
        
        local tabFrame = Instance.new("ScrollingFrame")
        tabFrame.Size = UDim2.new(1, -20, 1, -20)
        tabFrame.Position = UDim2.new(0, 10, 0, 10)
        tabFrame.BackgroundTransparency = 1
        tabFrame.BorderSizePixel = 0
        tabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
        tabFrame.ScrollBarThickness = 6
        tabFrame.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 100)
        tabFrame.Parent = ContentContainer
        tabFrame.Visible = false
        
        local uiList = Instance.new("UIListLayout")
        uiList.Padding = UDim.new(0, 8)
        uiList.SortOrder = Enum.SortOrder.LayoutOrder
        uiList.Parent = tabFrame
        
        local function updateCanvas()
            tabFrame.CanvasSize = UDim2.new(0, 0, 0, uiList.AbsoluteContentSize.Y + 10)
        end
        
        uiList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
        updateCanvas()
        
        tabButton.MouseButton1Click:Connect(function()
            for _, frame in pairs(window.Frames) do
                frame.Visible = false
            end
            for _, btn in pairs(window.Tabs) do
                btn.BackgroundTransparency = 0.5
                btn.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
            tabFrame.Visible = true
            tabButton.BackgroundTransparency = 0
            tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            window.CurrentTab = tabName
        end)
        
        table.insert(window.Tabs, tabButton)
        table.insert(window.Frames, tabFrame)
        
        if not window.CurrentTab then
            tabButton.BackgroundTransparency = 0
            tabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            tabFrame.Visible = true
            window.CurrentTab = tabName
        end
        
        function tab:CreateSection(sectionName)
