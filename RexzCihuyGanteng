--  SIDEBAR CATEGORY
-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function RexzLibrary:AddSidebarCategory(categoryName)
    local collapsed = false
    self.Categories = self.Categories or {}
    
    local linkedTabs = {}

    local Cat = Instance.new("TextButton")
    Cat.Name = "Category_" .. categoryName
    Cat.Size = UDim2.new(1, -4, 0, 20)
    Cat.BackgroundTransparency = 1
    Cat.BorderSizePixel = 0
    Cat.Text = ""
    Cat.AutoButtonColor = false

    local childCount = 0
    for _, c in ipairs(self.Sidebar:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextButton") then
            childCount = childCount + 1
        end
    end
    Cat.LayoutOrder = childCount + 1
    Cat.Parent = self.Sidebar

    local Line = Instance.new("Frame")
    Line.Size = UDim2.new(0, 10, 0, 1)
    Line.Position = UDim2.new(0, 6, 0.5, 0)
    Line.BackgroundColor3 = self.Theme.Stroke
    Line.BorderSizePixel = 0
    Line.Parent = Cat

    local CatText = Instance.new("TextLabel")
    CatText.Size = UDim2.new(1, -44, 1, 0)
    CatText.Position = UDim2.new(0, 20, 0, 0)
    CatText.BackgroundTransparency = 1
    CatText.Text = string.upper(categoryName)
    CatText.TextColor3 = self.Theme.Muted
    CatText.TextSize = 8
    CatText.Font = Enum.Font.GothamBold
    CatText.TextXAlignment = Enum.TextXAlignment.Left
    CatText.Parent = Cat

    local Arrow = Instance.new("TextLabel")
    Arrow.Size = UDim2.new(0, 16, 1, 0)
    Arrow.Position = UDim2.new(1, -18, 0, 0)
    Arrow.BackgroundTransparency = 1
    Arrow.Text = "v"
    Arrow.TextColor3 = self.Theme.Muted
    Arrow.TextSize = 8
    Arrow.Font = Enum.Font.GothamBold
    Arrow.TextXAlignment = Enum.TextXAlignment.Center
    Arrow.Parent = Cat

    Cat.MouseButton1Click:Connect(function()
        collapsed = not collapsed

        TweenService:Create(Arrow, TweenInfo.new(0.15), { TextColor3 = collapsed and self.Theme.Accent or self.Theme.Muted }):Play()
        Arrow.Text = collapsed and ">" or "v"

        for _, tabBtn in ipairs(linkedTabs) do
            if tabBtn and tabBtn.Parent then
                tabBtn.Visible = not collapsed

                if collapsed and self.CurrentTab and self.CurrentTab.BackgroundColor == tabBtn then
                    for _, t in ipairs(self.Tabs) do
                        if t.BackgroundColor and t.BackgroundColor.Visible and t.BackgroundColor.Parent == self.Sidebar then
                            t.BackgroundColor.BackgroundColor3 = self.Theme.TabActive
                            t.Label.TextColor3 = self.Theme.Accent
                            if t.Icon then t.Icon.ImageColor3 = self.Theme.Accent end
                            if t.ScrollBox then t.ScrollBox.Visible = true end
                            self.CurrentTab = t
                            break
                        end
                    end
                end
            end
        end
    end)

    Cat.MouseEnter:Connect(function() TweenService:Create(CatText, TweenInfo.new(0.1), { TextColor3 = self.Theme.Text }):Play() end)
    Cat.MouseLeave:Connect(function() TweenService:Create(CatText, TweenInfo.new(0.1), { TextColor3 = self.Theme.Muted }):Play() end)

    local catObj = {}
    function catObj:LinkTab(tabButton)
        table.insert(linkedTabs, tabButton)
        tabButton.Visible = not collapsed
    end

    catObj.Instance = Cat
    self.Categories[categoryName] = catObj
    return catObj
end

-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
--  CREATE TAB
-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
function RexzLibrary:CreateTab(tabName, iconId, isPinned, targetCategory)
    local tab = setmetatable({}, TabClass)
    tab.Library  = self
    tab.Elements = {}
    tab.Links    = {}

    local TabButton = Instance.new("TextButton")
    TabButton.Name = tabName .. "_TabBtn"
    TabButton.BackgroundColor3 = self.Theme.Element
    TabButton.Text = ""
    TabButton.BorderSizePixel = 0
    TabButton.AutoButtonColor = false

    if isPinned then
        TabButton.Size = UDim2.new(0, 130, 0, 32)
        TabButton.Position = UDim2.new(0, 4, 1, -38)
        TabButton.Parent = self.MainFrame
    else
        TabButton.Size = UDim2.new(1, -4, 0, 32)
        local childCount = 0
        for _, c in ipairs(self.Sidebar:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextButton") then
                childCount = childCount + 1
            end
        end
        TabButton.LayoutOrder = childCount + 1
        TabButton.Parent = self.Sidebar
        
        if targetCategory and self.Categories and self.Categories[targetCategory] then
            self.Categories[targetCategory]:LinkTab(TabButton)
        end
    end

    Corner(TabButton, 6)

    if iconId then
        local TabIcon = Instance.new("ImageLabel")
        TabIcon.Name = "TabIcon"
        TabIcon.Size = UDim2.new(0, 15, 0, 15)
        TabIcon.Position = UDim2.new(0, 10, 0.5, -7)
        TabIcon.BackgroundTransparency = 1
        TabIcon.Image = ResolveIcon(iconId)
        TabIcon.ImageColor3 = self.Theme.Icon
        TabIcon.Parent = TabButton
        tab.Icon = TabIcon
    end

    local TabLabel = Instance.new("TextLabel")
    TabLabel.Name = "TabLabel"
    TabLabel.Size = UDim2.new(1, iconId and -34 or -14, 1, 0)
    TabLabel.Position = UDim2.new(0, iconId and 30 or 10, 0, 0)
    TabLabel.BackgroundTransparency = 1
    TabLabel.Text = tabName
    TabLabel.TextColor3 = self.Theme.TextDim
    TabLabel.TextSize = 11
    TabLabel.Font = Enum.Font.GothamMedium
    TabLabel.TextXAlignment = Enum.TextXAlignment.Left
    TabLabel.Parent = TabButton
    tab.Label = TabLabel

    local ScrollBox = Instance.new("ScrollingFrame")
    ScrollBox.Name = tabName .. "_Scroll"
    ScrollBox.Size = UDim2.new(1, -4, 1, 0)
    ScrollBox.Position = UDim2.new(0, 2, 0, 0)
    ScrollBox.BackgroundTransparency = 1
    ScrollBox.BorderSizePixel = 0
    ScrollBox.ScrollBarThickness = 2
    ScrollBox.ScrollBarImageColor3 = self.Theme.Stroke
    ScrollBox.CanvasSize = UDim2.new(0, 0, 0, 0)
    ScrollBox.Visible = false
    ScrollBox.Parent = self.ContentHolder
    tab.ScrollBox = ScrollBox

    local ListLayout = Instance.new("UIListLayout")
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Padding = UDim.new(0, 5)
    ListLayout.Parent = ScrollBox

    ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        ScrollBox.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 8)
    end)

    local function ActivateTab()
        if not TabButton.Visible then return end
        
        for _, t in ipairs(self.Tabs) do
            if t.ScrollBox then t.ScrollBox.Visible = false end
            if t.BackgroundColor then t.BackgroundColor.BackgroundColor3 = self.Theme.Element end
            if t.Label then t.Label.TextColor3 = self.Theme.TextDim end
            if t.Icon  then t.Icon.ImageColor3  = self.Theme.Icon  end
        end
        ScrollBox.Visible = true
        TabButton.BackgroundColor3 = self.Theme.TabActive
        TabLabel.TextColor3 = self.Theme.Accent
        if tab.Icon then tab.Icon.ImageColor3 = self.Theme.Accent end
        self.CurrentTab = tab
        self:RefreshCurrentSearch()
    end

    TabButton.MouseButton1Click:Connect(ActivateTab)
    TabButton.MouseEnter:Connect(function()
        if self.CurrentTab ~= tab then TweenService:Create(TabButton, TweenInfo.new(0.12), { BackgroundColor3 = self.Theme.TabActive }):Play() end
    end)
    TabButton.MouseLeave:Connect(function()
        if self.CurrentTab ~= tab then TweenService:Create(TabButton, TweenInfo.new(0.12), { BackgroundColor3 = self.Theme.Element }):Play() end
    end)

    tab.BackgroundColor = TabButton
    tab.Button = TabButton
    table.insert(self.Tabs, tab)

    if #self.Tabs == 1 and tabName ~= "Credits" then ActivateTab() end
    self:ApplyTheme(self.Theme)

    return tab
end

