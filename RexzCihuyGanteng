    local function ApplyGlobalAccent(newColor)
        self.AccentColor = newColor
        ToggleStroke.Color = newColor
        ToggleIcon.ImageColor3 = newColor
        MainIcon.ImageColor3 = newColor
        
        local hexStr = newColor:ToHex()
        TitleLabel.Text = fixedHubName .. " <font color='#" .. hexStr .. "'>|</font> " .. title
        
        for _, t in ipairs(self.Tabs) do
            if self.CurrentTab == t then
                t.Label.TextColor3 = newColor
                if t.Icon then t.Icon.ImageColor3 = newColor end
            end
            for _, element in ipairs(t.Elements) do
                if element.UpdateTheme then element.UpdateTheme() end
            end
        end
        if ConfigTab then
            for _, element in ipairs(ConfigTab.Elements) do
                if element.UpdateTheme then element.UpdateTheme() end
            end
        end
    end

