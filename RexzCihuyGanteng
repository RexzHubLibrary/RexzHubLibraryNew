    DropdownUIList.Padding = UDim.new(0, 2)
    DropdownUIList.SortOrder = Enum.SortOrder.LayoutOrder
    DropdownUIList.Parent = DropdownList
    
    local function UpdateDropdownSize()
        local Count = #options
        local Height = math.min(Count * 40, 180)
        DropdownList.Size = UDim2.new(1, 0, 0, Height)
        DropdownFrame.Size = UDim2.new(1, 0, 0, 52 + Height)
        DropdownList.CanvasSize = UDim2.new(0, 0, 0, DropdownUIList.AbsoluteContentSize.Y)
    end
    
    for _, option in ipairs(options) do
        local OptionBtn = Instance.new("TextButton")
        OptionBtn.Size = UDim2.new(1, -8, 0, 38)
        OptionBtn.Position = UDim2.new(0, 4, 0, 0)
        OptionBtn.BackgroundColor3 = Colors.Card
        OptionBtn.Text = "  •  " .. option
        OptionBtn.TextColor3 = Colors.TextSecondary
        OptionBtn.TextSize = 13
        OptionBtn.TextXAlignment = Enum.TextXAlignment.Left
        OptionBtn.Font = Enum.Font.Gotham
        OptionBtn.BorderSizePixel = 0
        OptionBtn.Parent = DropdownList
        
        local OptionCorner = Instance.new("UICorner")
        OptionCorner.CornerRadius = UDim.new(0, 6)
        OptionCorner.Parent = OptionBtn
        
        OptionBtn.MouseButton1Click:Connect(function()
            SelectedValue = option
            DropdownLabel.Text = "  📋  " .. text .. ": " .. SelectedValue
            DropdownOpen = false
            DropdownList.Visible = false
            DropdownFrame.Size = UDim2.new(1, 0, 0, 52)
            if callback then callback(SelectedValue) end
        end)
    end
    
    DropdownBtn.MouseButton1Click:Connect(function()
        DropdownOpen = not DropdownOpen
        DropdownList.Visible = DropdownOpen
        if DropdownOpen then
            UpdateDropdownSize()
        else
            DropdownFrame.Size = UDim2.new(1, 0, 0, 52)
        end
    end)
    
    table.insert(self.Elements, DropdownFrame)
    return DropdownBtn, function() return SelectedValue end
end

