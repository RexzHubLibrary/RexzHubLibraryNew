    IconSupport = loadstring(game:HttpGet(ICON_SUPPORT_URL))()
end)

local function ResolveIcon(icon)
    if not icon then return nil end

    if typeof(icon) == "number" then  
        return "rbxassetid://" .. tostring(icon)  
    end  

    if typeof(icon) == "string" then  
        if icon:match("^rbxassetid://") or icon:match("^http") then  
            return icon  
        end  

        local fixed = IconSupport[icon]  
            or IconSupport[icon:sub(1,1):upper() .. icon:sub(2)]  
            or IconSupport[string.upper(icon)]  

        if fixed then return fixed end
    end  
    return nil
end

local function Clamp255(n)
    n = tonumber(n) or 0
    return math.clamp(math.floor(n), 0, 255)
end

local function ColorToHex(c)
    return string.format("#%02X%02X%02X", Clamp255(c.R * 255), Clamp255(c.G * 255), Clamp255(c.B * 255))
end

local function HexToColor(hex, fallback)
    if typeof(hex) ~= "string" then return fallback end

    hex = hex:gsub("#", ""):gsub("0x", "")  
    if #hex ~= 6 then return fallback end  

    local r = tonumber(hex:sub(1, 2), 16)  
    local g = tonumber(hex:sub(3, 4), 16)  
    local b = tonumber(hex:sub(5, 6), 16)  
    if not r or not g or not b then return fallback end  

    return Color3.fromRGB(r, g, b)
end

local function SanitizeName(name)
    name = tostring(name or "")
    name = name:gsub("[%/%:*%?\"<>|]", "")
    name = name:gsub("%s+", "")
    name = name:gsub("%+", "")
    name = name:gsub("%^", ""):gsub("%$", "")
    if name == "" then name = "Profile" end
    return name
end

local function FileExists(path)
    if isfile then
        local ok, res = pcall(isfile, path)
        return ok and res
    end
    return false
end

local function EnsureFolder(path)
    if makefolder and not isfolder(path) then
        pcall(makefolder, path)
    end
end

function RexzLibrary:ApplyTheme(theme)
    theme = theme or self.Theme
    self.Theme = theme

    if self.MainFrame then  
        self.MainFrame.BackgroundColor3 = theme.Background  
        local stroke = self.MainFrame:FindFirstChildOfClass("UIStroke")  
        if stroke then stroke.Color = theme.Stroke end  
    end  

    if self.TopBar then  
        self.TopBar.BackgroundColor3 = theme.Topbar  
    end  

    if self.ToggleBtn then  
        self.ToggleBtn.BackgroundColor3 = theme.Element  
        local stroke = self.ToggleBtn:FindFirstChildOfClass("UIStroke")  
        if stroke then stroke.Color = theme.Accent end  
        local icon = self.ToggleBtn:FindFirstChild("ToggleIcon")  
        if icon then icon.ImageColor3 = theme.Accent end  
    end  

    if self.SearchFrame then  
        self.SearchFrame.BackgroundColor3 = theme.Element  
        local stroke = self.SearchFrame:FindFirstChildOfClass("UIStroke")  
        if stroke then stroke.Color = theme.Stroke end  
    end  

    for _, tab in ipairs(self.Tabs or {}) do  
        if tab.BackgroundColor then  
            if tab == self.CurrentTab then  
                tab.BackgroundColor.BackgroundColor3 = theme.TabActive  
                tab.Label.TextColor3 = theme.Accent  
                if tab.Icon then tab.Icon.ImageColor3 = theme.Accent end  
            else  
                tab.BackgroundColor.BackgroundColor3 = theme.Element  
                tab.Label.TextColor3 = theme.TextDim  
                if tab.Icon then tab.Icon.ImageColor3 = theme.Icon end  
            end  
        end  
    end  

    for _, ref in ipairs(self.ControlRegistry or {}) do  
        if ref.Root and ref.Root.Parent then  
            ref.Root.BackgroundColor3 = (ref.Kind == "Dropdown") and theme.DropdownBg or (ref.Kind == "Input" and theme.InputBg or (ref.Kind == "Label" and theme.LabelBg or theme.Element))
            local stroke = ref.Root:FindFirstChildOfClass("UIStroke")  
            if stroke then stroke.Color = theme.Stroke end  
        end  

        if ref.Title then ref.Title.TextColor3 = theme.Text end  
        if ref.Icon then ref.Icon.ImageColor3 = theme.Icon end  

        if ref.Kind == "Button" then  
            if ref.Text then ref.Text.TextColor3 = theme.Text end  
        elseif ref.Kind == "Toggle" then  
            if ref.Text then ref.Text.TextColor3 = theme.Text end  
            if ref.Indicator then  
                ref.Indicator.BackgroundColor3 = ref.State and theme.ToggleOnBg or theme.ToggleOffBg  
                local s = ref.Indicator:FindFirstChildOfClass("UIStroke")  
                if s then s.Color = ref.State and theme.Accent or theme.Stroke end  
            end  
            if ref.RLogo then  
                ref.RLogo.TextColor3 = ref.State and theme.Accent or theme.Muted  
            end  
        elseif ref.Kind == "Dropdown" then  
            if ref.ValueLabel then ref.ValueLabel.TextColor3 = theme.TextDim end  
            if ref.Arrow then ref.Arrow.TextColor3 = theme.Muted end  
        elseif ref.Kind == "Input" then  
            if ref.Box then  
                ref.Box.TextColor3 = theme.Text  
                ref.Box.PlaceholderColor3 = theme.Muted  
            end  
        elseif ref.Kind == "Label" then  
            if ref.SubText then ref.SubText.TextColor3 = theme.Muted end  
        end  
    end
end

function RexzLibrary:RefreshSaveProfiles()
    if not self.SaveDropdown then return end

    local list = {}  
    if listfiles and isfolder and isfolder(self.SaveFolder) then  
        for _, file in ipairs(listfiles(self.SaveFolder)) do  
            if file:sub(-5) == ".json" then  
                local name = file:match("([^/%\\]+)%.json$")  
                if name then table.insert(list, name) end  
            end  
        end  
    end  

    table.sort(list, function(a, b)  
        return tostring(a):lower() < tostring(b):lower()  
    end)  
    
    if #list == 0 then list = { "Belum ada profile" } end  
    
    if self.SaveDropdown.SetOptions then
        self.SaveDropdown:SetOptions(list, list[1], false)
    elseif self.SaveDropdown.Refresh then
        self.SaveDropdown:Refresh(list, true)
    end
end

function RexzLibrary:SaveProfile(profileName)
    if not writefile then
        self:Notify("Save Gagal", "Executor kamu tidak mendukung writefile.", 4)
        return false
    end

    EnsureFolder(self.SaveFolder)  
    local safeName = SanitizeName(profileName)  
    local path = self.SaveFolder .. "/" .. safeName .. ".json"  

    local data = {  
        Theme = {  
            Background = ColorToHex(self.Theme.Background),  
            Topbar = ColorToHex(self.Theme.Topbar),  
            Sidebar = ColorToHex(self.Theme.Sidebar),  
            Element = ColorToHex(self.Theme.Element),  
            TabActive = ColorToHex(self.Theme.TabActive),  
            Accent = ColorToHex(self.Theme.Accent),  
            Text = ColorToHex(self.Theme.Text),  
            TextDim = ColorToHex(self.Theme.TextDim),  
            Icon = ColorToHex(self.Theme.Icon),  
            Stroke = ColorToHex(self.Theme.Stroke),  
            ToggleOnBg = ColorToHex(self.Theme.ToggleOnBg),  
            ToggleOffBg = ColorToHex(self.Theme.ToggleOffBg),  
            DropdownBg = ColorToHex(self.Theme.DropdownBg),  
            InputBg = ColorToHex(self.Theme.InputBg),  
            LabelBg = ColorToHex(self.Theme.LabelBg),
            Muted = ColorToHex(self.Theme.Muted)
        },  
        Toggles = self.ToggleStates or {}  
    }  

    local encoded = HttpService:JSONEncode(data)  
    pcall(writefile, path, encoded)  

    self:Notify("Profile Disimpan", "Profile \"" .. safeName .. "\" berhasil disimpan.", 4)  
    self:RefreshSaveProfiles()  
    return true
end

function RexzLibrary:DeleteProfile(profileName)
    if not delfile then
        self:Notify("Hapus Gagal", "Executor kamu tidak mendukung delfile.", 4)
        return false
    end

    local safeName = SanitizeName(profileName)  
    local path = self.SaveFolder .. "/" .. safeName .. ".json"  

    if not FileExists(path) then  
        self:Notify("Hapus Gagal", "Profile \"" .. safeName .. "\" tidak ditemukan.", 4)  
        return false  
    end  

    local ok, err = pcall(delfile, path)  
    if not ok then  
        self:Notify("Hapus Gagal", "Gagal menghapus file profile.", 4)  
        return false  
    end  

    self:Notify("Profile Dihapus", "Profile \"" .. safeName .. "\" berhasil dihapus.", 4)  
    self:RefreshSaveProfiles()  
    return true
end


function RexzLibrary:LoadProfile(profileName)
    if not readfile then
        self:Notify("Load Gagal", "Executor kamu tidak mendukung readfile.", 4)
        return false
    end

    local safeName = SanitizeName(profileName)  
    local path = self.SaveFolder .. "/" .. safeName .. ".json"  

    if not FileExists(path) then  
        self:Notify("Load Gagal", "Profile \"" .. safeName .. "\" tidak ditemukan.", 4)  
        return false  
    end  

    local ok, raw = pcall(readfile, path)  
    if not ok or not raw then  
        self:Notify("Load Gagal", "File profile gagal dibaca.", 4)  
        return false  
    end  

    local okDecode, data = pcall(function() return HttpService:JSONDecode(raw) end)  
    if not okDecode or type(data) ~= "table" then  
        self:Notify("Load Gagal", "Format profile tidak valid.", 4)  
        return false  
    end  

    if data.Theme then  
        for key, value in pairs(data.Theme) do
            self.Theme[key] = HexToColor(value, self.Theme[key])
        end
    end  

    if data.Toggles and type(data.Toggles) == "table" then  
        for name, value in pairs(data.Toggles) do  
            local reg = self.ToggleRegistry and self.ToggleRegistry[name]  
            if reg and reg.SetState then reg.SetState(value, true) end  
        end  
    end  

    self:ApplyTheme(self.Theme)  

    if self.SettingsRefs then  
        if self.SettingsRefs.AccentBox then self.SettingsRefs.AccentBox.Text = ColorToHex(self.Theme.Accent) end  
        if self.SettingsRefs.BackgroundBox then self.SettingsRefs.BackgroundBox.Text = ColorToHex(self.Theme.Background) end  
    end  

    self:Notify("Profile Dimuat", "Profile \"" .. safeName .. "\" berhasil dimuat.", 4)  
    return true
end

