function Tab.New(name, icon, windowData)
    local self = setmetatable({}, Tab)
    self.Name = name
    self.Icon = icon or "📁"
    self.Elements = {}
    self.Container = nil
    
    -- Tab Button
    local TabButton = Instance.new("TextButton")
    TabButton.Size = UDim2.new(1, -16, 0, 42)
    TabButton.Position = UDim2.new(0, 8, 0, 0)
    TabButton.BackgroundColor3 = Colors.Surface
    TabButton.BackgroundTransparency = 0.5
    TabButton.Text = "  " .. self.Icon .. "  " .. self.Name
    TabButton.TextColor3 = Colors.TextSecondary
    TabButton.TextSize = 14
    TabButton.TextXAlignment = Enum.TextXAlignment.Left
    TabButton.Font = Enum.Font.GothamSemibold
    TabButton.BorderSizePixel = 0
    TabButton.Parent = windowData.SidebarScroll
    
    local TabCorner = Instance.new("UICorner")
    TabCorner.CornerRadius = UDim.new(0, 8)
    TabCorner.Parent = TabButton
    
    -- Tab Content Container
    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Size = UDim2.new(1, 0, 1, 0)
    TabContainer.BackgroundTransparency = 1
    TabContainer.BorderSizePixel = 0
    TabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabContainer.ScrollBarThickness = 4
    TabContainer.ScrollBarImageColor3 = Colors.Primary
    TabContainer.Visible = false
    TabContainer.Parent = windowData.ContentScroll
    
    local TabList = Instance.new("UIListLayout")
    TabList.Padding = UDim.new(0, 12)
    TabList.SortOrder = Enum.SortOrder.LayoutOrder
    TabList.Parent = TabContainer
    
    self.Container = TabContainer
    self.TabList = TabList
    self.TabButton = TabButton
    
    -- Click Handler
    TabButton.MouseButton1Click:Connect(function()
        for _, tab in pairs(AllTabs) do
            if tab.Container then
                tab.Container.Visible = false
                tab.TabButton.BackgroundTransparency = 0.5
                tab.TabButton.TextColor3 = Colors.TextSecondary
            end
        end
        TabContainer.Visible = true
        TabButton.BackgroundTransparency = 0
        TabButton.TextColor3 = Colors.Text
        ActiveTab = self
    end)
    
    -- Select first tab
    if #AllTabs == 0 then
        TabContainer.Visible = true
        TabButton.BackgroundTransparency = 0
        TabButton.TextColor3 = Colors.Text
        ActiveTab = self
    end
    
    table.insert(AllTabs, self)
    
    return self
end

