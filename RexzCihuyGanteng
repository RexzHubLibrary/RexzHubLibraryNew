-- [ FUNGSI ANIMASI DASAR ]
local function Tween(instance, prop, time)
    local tween = TweenService:Create(instance, TweenInfo.new(time or 0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), prop)
    tween:Play()
    return tween
end

