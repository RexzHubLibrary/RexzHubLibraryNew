-- Fungsi internal untuk cek apakah input itu Nama Icon atau ID angka asli
local function getIconId(input)
    if type(input) == "string" and RexzLibrary.Icons[input] then
        return "rbxassetid://" .. tostring(RexzLibrary.Icons[input])
    elseif type(input) == "number" then
        return "rbxassetid://" .. tostring(input)
    elseif type(input) == "string" and input:match("^%d+$") then
        return "rbxassetid://" .. input
    end
    return "rbxassetid://10723351943" -- Default Home Icon jika kosong
end

