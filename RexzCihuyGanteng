	local t1 = new("TextLabel", {
		Size = UDim2.new(1, -24, 0, 18),
		Position = UDim2.new(0, 12, 0, 8),
		BackgroundTransparency = 1,
		Text = tostring(titleText),
		TextColor3 = Color3.fromRGB(240, 240, 245),
		TextSize = 12,
		Font = Enum.Font.GothamBold,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = box,
	})

	local t2 = new("TextLabel", {
		Size = UDim2.new(1, -24, 0, 22),
		Position = UDim2.new(0, 12, 0, 26),
		BackgroundTransparency = 1,
		Text = tostring(bodyText),
		TextColor3 = Color3.fromRGB(175, 175, 185),
		TextSize = 11,
		Font = Enum.Font.GothamMedium,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		Parent = box,
	})

	TweenService:Create(box, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 0, 0),
	}):Play()

	task.delay(duration or 3.5, function()
		if not box.Parent then return end
		local tw = TweenService:Create(box, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Position = UDim2.new(1, 30, 0, 0),
			BackgroundTransparency = 1,
		})
		tw:Play()
		tw.Completed:Connect(function()
			if box then box:Destroy() end
		end)
	end)
end

function RexzLibrary:SwitchToTab(tab)
	if not tab then return end

	if self.ConfigTab then
		self.ConfigTab.ScrollBox.Visible = false
		self.ConfigTab.Button.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
		self.ConfigTab.Label.TextColor3 = Color3.fromRGB(160, 160, 170)
		self.ConfigTab.Icon.ImageColor3 = Color3.fromRGB(150, 150, 160)
	end

	for _, t in ipairs(self.Tabs) do
		t.ScrollBox.Visible = false
		t.Button.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
		t.Label.TextColor3 = Color3.fromRGB(160, 160, 170)
		if t.Icon then t.Icon.ImageColor3 = Color3.fromRGB(150, 150, 160) end
	end

	tab.ScrollBox.Visible = true
	tab.Button.BackgroundColor3 = Color3.fromRGB(32, 30, 42)
	tab.Label.TextColor3 = self.AccentColor
	if tab.Icon then tab.Icon.ImageColor3 = self.AccentColor end

	self.CurrentTab = tab
	self:ApplySearch()
end

function RexzLibrary:SwitchToConfig()
	if self.CurrentTab then
		self.CurrentTab.ScrollBox.Visible = false
		self.CurrentTab.Button.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
		self.CurrentTab.Label.TextColor3 = Color3.fromRGB(160, 160, 170)
		if self.CurrentTab.Icon then self.CurrentTab.Icon.ImageColor3 = Color3.fromRGB(150, 150, 160) end
	end

	for _, t in ipairs(self.Tabs) do
		t.ScrollBox.Visible = false
		t.Button.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
		t.Label.TextColor3 = Color3.fromRGB(160, 160, 170)
		if t.Icon then t.Icon.ImageColor3 = Color3.fromRGB(150, 150, 160) end
	end

	self.ConfigTab.ScrollBox.Visible = true
	self.ConfigTab.Button.BackgroundColor3 = Color3.fromRGB(32, 30, 42)
	self.ConfigTab.Label.TextColor3 = self.AccentColor
	self.ConfigTab.Icon.ImageColor3 = self.AccentColor
	self.CurrentTab = self.ConfigTab
	self:ApplySearch()
end

function RexzLibrary:ApplySearch()
	local q = string.lower(self.SearchInput.Text or "")
	local tab = self.CurrentTab
	if not tab then return end

	for _, item in ipairs(tab.Elements) do
		if item.Instance then
			if q == "" then
				item.Instance.Visible = true
			else
				local name = string.lower(item.Name or "")
				item.Instance.Visible = string.find(name, q, 1, true) and true or false
			end
		end
	end
end

function RexzLibrary:SaveConfig(slotName)
	local path = "Rexz_" .. tostring(slotName or "default") .. ".json"
	local data = {
		Accent = { self.AccentColor.R, self.AccentColor.G, self.AccentColor.B },
		State = {},
	}

	for key, entry in pairs(self._registry) do
		if entry.Get then
			data.State[key] = entry.Get()
		end
	end

	local encoded = HttpService:JSONEncode(data)

	if writefile then
		writefile(path, encoded)
		self:Notify("Config", "Tersimpan ke " .. path, 3)
	else
		self:Notify("Config", "writefile tidak tersedia di environment ini", 4)
	end
end

function RexzLibrary:LoadConfig(slotName)
	local path = "Rexz_" .. tostring(slotName or "default") .. ".json"

	if not readfile then
		self:Notify("Config", "readfile tidak tersedia di environment ini", 4)
		return
	end

	if not isfile(path) then
		self:Notify("Config", "File config tidak ditemukan", 4)
		return
	end

	local ok, decoded = pcall(function()
		return HttpService:JSONDecode(readfile(path))
	end)

	if not ok or type(decoded) ~= "table" then
		self:Notify("Config", "Config rusak / gagal dibaca", 4)
		return
	end

	if decoded.Accent and decoded.Accent[1] then
		self:SetAccent(Color3.new(decoded.Accent[1], decoded.Accent[2], decoded.Accent[3]))
	end

	if decoded.State then
		for key, value in pairs(decoded.State) do
			local entry = self._registry[key]
			if entry and entry.Apply then
				safeCall(entry.Apply, value, true)
			end
		end
	end

	self:Notify("Config", "Config berhasil di-load", 3)
end

function RexzLibrary:Destroy()
	for _, c in ipairs(self._connections) do
		pcall(function() c:Disconnect() end)
	end
	if self.ScreenGui then
		self.ScreenGui:Destroy()
	end
end

