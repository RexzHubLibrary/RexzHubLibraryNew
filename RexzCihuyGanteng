    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = NotifBox

    local DescLabel = Instance.new("TextLabel")
    DescLabel.Name = "NotifDesc"
    DescLabel.Size = UDim2.new(1, -24, 0, 22)
    DescLabel.Position = UDim2.new(0, 12, 0, 28)
    DescLabel.BackgroundTransparency = 1
    DescLabel.Text = tostring(notifText)
    DescLabel.TextColor3 = self.Themes[self.CurrentTheme].textSec
    DescLabel.TextSize = 11
    DescLabel.Font = Enum.Font.GothamMedium
    DescLabel.TextXAlignment = Enum.TextXAlignment.Left
    DescLabel.TextWrapped = true
    DescLabel.Parent = NotifBox

    local tweenIn = TweenService:Create(NotifBox, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    })
    tweenIn:Play()

    task.delay(viewTime, function()
        local tweenOut = TweenService:Create(NotifBox, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(1, 30, 0, 0),
            BackgroundTransparency = 1
        })
        tweenOut:Play()
        tweenOut.Completed:Connect(function()
            NotifBox:Destroy()
        end)
    end)
end

-- METHOD: CREATE TAB
function RexzLibrary:CreateTab(tabName, iconId)
    local tab = setmetatable({}, TabClass)
    tab.Elements = {}
    tab.TabName = tabName
    local theme = self.Themes[self.CurrentTheme]
    
    local TabButton = Instance.new("TextButton")
    TabButton.Name = tabName .. "_TabBtn"
    TabButton.Size = UDim2.new(1, -5, 0, 34)
    TabButton.BackgroundColor3 = theme.card
    TabButton.Text = ""
    TabButton.BorderSizePixel = 0
    TabButton.LayoutOrder = (tabName == "Credit" or tabName == "Settings") and 9999 or (#self.Tabs + 1)
    TabButton.Parent = self.MainFrame.Sidebar

    local TabBtnCorner = Instance.new("UICorner")
    TabBtnCorner.CornerRadius = UDim.new(0, 6)
    TabBtnCorner.Parent = TabButton

    if iconId then
        local TabIcon = Instance.new("ImageLabel")
        TabIcon.Name = "TabIcon"
        TabIcon.Size = UDim2.new(0, 16, 0, 16)
        TabIcon.Position = UDim2.new(0, 10, 0.5, -8)
        TabIcon.BackgroundTransparency = 1
        TabIcon.Image = "rbxassetid://" .. tostring(iconId)
        TabIcon.ImageColor3 = theme.textSec
        TabIcon.Parent = TabButton
        tab.Icon = TabIcon
    end

    local TabLabel = Instance.new("TextLabel")
    TabLabel.Name = "TabLabel"
    TabLabel.Size = UDim2.new(1, iconId and -36 or -16, 1, 0)
    TabLabel.Position = UDim2.new(0, iconId and 32 or 12, 0, 0)
    TabLabel.BackgroundTransparency = 1
    TabLabel.Text = tabName
    TabLabel.TextColor3 = theme.textSec
    TabLabel.TextSize = 12
    TabLabel.Font = Enum.Font.GothamMedium
    TabLabel.TextXAlignment = Enum.TextXAlignment.Left
    TabLabel.Parent = TabButton
    tab.Label = TabLabel

    local ScrollBox = Instance.new("ScrollingFrame")
    ScrollBox.Name = tabName .. "_ContentScroll"
    ScrollBox.Size = UDim2.new(1, 0, 1, 0)
    ScrollBox.BackgroundTransparency = 1
    ScrollBox.BorderSizePixel = 0
    ScrollBox.ScrollBarThickness = 3
    ScrollBox.ScrollBarImageColor3 = self.Themes[self.CurrentTheme].border
    ScrollBox.CanvasSize = UDim2.new(0, 0, 0, 0)
    ScrollBox.Visible = false
    ScrollBox.Parent = self.ContentHolder
    tab.ScrollBox = ScrollBox

    local ListLayout = Instance.new("UIListLayout")
    ListLayout.Parent = ScrollBox
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Padding = UDim.new(0, 6)

    ListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        ScrollBox.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 10)
    end)

    local function ActivateTab()
        for _, t in ipairs(self.Tabs) do
            t.ScrollBox.Visible = false
            t.BackgroundColor.BackgroundColor3 = self.Themes[self.CurrentTheme].card
            t.Label.TextColor3 = self.Themes[self.CurrentTheme].textSec
            if t.Icon then t.Icon.ImageColor3 = self.Themes[self.CurrentTheme].textSec end
        end        ScrollBox.Visible = true 
        TabButton.BackgroundColor3 = Color3.fromRGB(
            self.Themes[self.CurrentTheme].card.R * 255 + 10,
            self.Themes[self.CurrentTheme].card.G * 255 + 8,
            self.Themes[self.CurrentTheme].card.B * 255 + 12
        )
        TabLabel.TextColor3 = self.Themes[self.CurrentTheme].accent
        if tab.Icon then tab.Icon.ImageColor3 = self.Themes[self.CurrentTheme].accent end
        self.CurrentTab = tab
        
        -- Reset search
        self.MainFrame.SearchBarContainer.SearchInput.Text = ""
    end

    TabButton.MouseButton1Click:Connect(ActivateTab)
    
    tab.BackgroundColor = TabButton
    table.insert(self.Tabs, tab)

    if #self.Tabs == 1 and tabName ~= "Credit" and tabName ~= "Settings" then
        ActivateTab()
    end

    return tab
end

