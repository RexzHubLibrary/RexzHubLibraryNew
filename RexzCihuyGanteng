function TabClass:AddSlider(text, iconId, min, max, default, callback)
    local lib    = self.Library
    local value  = default or min
    local action = callback or function() end

    local El = Instance.new("Frame")
    El.Name = text .. "_Slider"
    El.Size = UDim2.new(1, -4, 0, 52)
    El.BackgroundColor3 = lib.Theme.Element
    El.BorderSizePixel = 0
    El.Parent = self.ScrollBox
    Corner(El, 6)
    Stroke(El, lib.Theme.Stroke, 1)

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -56, 0, 18)
    Label.Position = UDim2.new(0, 10, 0, 6)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = lib.Theme.Text
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = El

    local ValLabel = Instance.new("TextLabel")
    ValLabel.Size = UDim2.new(0, 44, 0, 18)
    ValLabel.Position = UDim2.new(1, -50, 0, 6)
    ValLabel.BackgroundTransparency = 1
    ValLabel.Text = tostring(value)
    ValLabel.TextColor3 = lib.Theme.Accent
    ValLabel.Font = Enum.Font.GothamBold
    ValLabel.TextSize = 12
    ValLabel.TextXAlignment = Enum.TextXAlignment.Right
    ValLabel.Parent = El

    local TrackBg = Instance.new("Frame")
    TrackBg.Size = UDim2.new(1, -20, 0, 5)
    TrackBg.Position = UDim2.new(0, 10, 0, 34)
    TrackBg.BackgroundColor3 = lib.Theme.ToggleOffBg
    TrackBg.BorderSizePixel = 0
    TrackBg.Parent = El
    Corner(TrackBg, 4)

    local Fill = Instance.new("Frame")
    Fill.Size = UDim2.new((value-min)/(max-min), 0, 1, 0)
    Fill.BackgroundColor3 = lib.Theme.Accent
    Fill.BorderSizePixel = 0
    Fill.Parent = TrackBg
    Corner(Fill, 4)

    local dragging = false

    local function Update(input)
        local pct = math.clamp(
            (input.Position.X - TrackBg.AbsolutePosition.X) / TrackBg.AbsoluteSize.X,
            0, 1)
        value = math.floor(min + (max - min) * pct)
        Fill.Size = UDim2.new(pct, 0, 1, 0)
        ValLabel.Text = tostring(value)
        pcall(action, value)
    end

    TrackBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            Update(input)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            Update(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        GetValue = function() return value end,
        SetValue = function(v)
            value = math.clamp(v, min, max)
            Fill.Size = UDim2.new((value-min)/(max-min), 0, 1, 0)
            ValLabel.Text = tostring(value)
        end
    }
end

