    local function MinimizeWindow()
        if self.Hidden then return end 
        self.Minimized = not self.Minimized
        if self.Minimized then
            ResizeGrip.Visible = false
            TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, MainFrame.Size.X.Offset, 0, 38)
            }):Play()
        else
            ResizeGrip.Visible = true
            TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = baseSize }):Play()
        end
    end

    local function ToggleHideWindow()
        self.Hidden = not self.Hidden
        if self.Hidden then
            ResizeGrip.Visible = false
            local tweenScale = TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Size = self.Minimized and UDim2.new(0, baseSize.X.Offset - 50, 0, 38) or UDim2.new(0, baseSize.X.Offset - 50, 0, baseSize.Y.Offset - 30),
                BackgroundTransparency = 1
            })
            tweenScale:Play()
            tweenScale.Completed:Connect(function() MainFrame.Visible = false end)
        else
            MainFrame.Visible = true
            ResizeGrip.Visible = not self.Minimized
            TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = self.Minimized and UDim2.new(0, baseSize.X.Offset, 0, 38) or baseSize,
                BackgroundTransparency = 0
            }):Play()
        end
    end

