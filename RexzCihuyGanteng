    local function CycleTheme()
        local themes = {"dark", "light", "purple", "ocean", "sunset"}
        local currentIndex = nil
        for i, t in ipairs(themes) do
            if t == self.CurrentTheme then
                currentIndex = i
                break
            end
        end
        local nextIndex = (currentIndex % #themes) + 1
        self.CurrentTheme = themes[nextIndex]
        self.applyTheme()
        self:Notify("Theme Changer", "Theme changed to: " .. self.CurrentTheme:upper(), 2.5)
        self:SaveConfig(self.CurrentConfigName or "default")
    end
