    -- Apply Theme Function
    local function applyTheme()
        local theme = self.Themes[self.CurrentTheme] or self.Themes.dark
        
        if self.MainFrame then
            self.MainFrame.BackgroundColor3 = theme.bg
            if self.MainStroke then self.MainStroke.Color = theme.border end
        end
        if self.TopBar then 
            self.TopBar.BackgroundColor3 = theme.surface
            if self.TopFix then self.TopFix.BackgroundColor3 = theme.surface end
        end
        if self.SearchFrame then 
            self.SearchFrame.BackgroundColor3 = theme.card
            if self.SearchStroke then self.SearchStroke.Color = theme.border end
        end
        
        -- Update all tabs
        for _, tab in ipairs(self.Tabs) do
            if tab.BackgroundColor then
                if tab == self.CurrentTab then
                    tab.BackgroundColor.BackgroundColor3 = Color3.fromRGB(
                        theme.card.R * 255 + 10,
                        theme.card.G * 255 + 8,
                        theme.card.B * 255 + 12
                    )
                else
                    tab.BackgroundColor.BackgroundColor3 = theme.card
                end
            end
            if tab.Label then
                tab.Label.TextColor3 = tab == self.CurrentTab and theme.accent or theme.textSec
            end
            if tab.Icon then
                tab.Icon.ImageColor3 = tab == self.CurrentTab and theme.accent or theme.textSec
            end
        end
        
        -- Update Toggle Button
        if self.ToggleBtn then
            self.ToggleBtn.BackgroundColor3 = theme.surface
            if self.ToggleStroke then self.ToggleStroke.Color = theme.accent end
            if self.ToggleIcon then self.ToggleIcon.ImageColor3 = theme.accent end
        end
        
        -- Update Title
        if self.TitleLabel then
            self.TitleLabel.TextColor3 = theme.text
        end
        if self.MainIcon then
            self.MainIcon.ImageColor3 = theme.accent
        end
    end
    
