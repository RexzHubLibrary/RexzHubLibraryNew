function TabClass:AddButton(text, iconId, callback)
    local action = callback or function() end
    local theme = self.ParentTab and self.ParentTab.ParentTab and self.ParentTab.ParentTab.Themes[self.ParentTab.ParentTab.CurrentTheme] or RexzLibrary.Themes.dark
    
    local ButtonElement = Instance.new("TextButton")
    ButtonElement.Name = text .. "_Interaction"
    ButtonElement.Size = UDim2.new(1, -4, 0, 36)
    ButtonElement.BackgroundColor3 = theme.card
    ButtonElement.BorderSizePixel = 0
    ButtonElement.Text = ""
    ButtonElement.AutoButtonColor = true
    ButtonElement.Parent = self.ScrollBox

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = ButtonElement

    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Color = theme.border
    BtnStroke.Thickness = 1
    BtnStroke.Parent = ButtonElement

    if iconId then
        local IconSpec = Instance.new("ImageLabel")
        IconSpec.Name = "ButtonIcon"
        IconSpec.Size = UDim2.new(0, 16, 0, 16)
        IconSpec.Position = UDim2.new(0, 10, 0.5, -8)
        IconSpec.BackgroundTransparency = 1
        IconSpec.Image = "rbxassetid://" .. tostring(iconId)
        IconSpec.ImageColor3 = theme.textSec
        IconSpec.Parent = ButtonElement
    end

    local Label = Instance.new("TextLabel")
    Label.Name = "ButtonLabel"
    Label.Size = UDim2.new(1, iconId and -40 or -20, 1, 0)
    Label.Position = UDim2.new(0, iconId and 34 or 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = theme.text
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ButtonElement

    ButtonElement.MouseButton1Click:Connect(function()
        local originalColor = ButtonElement.BackgroundColor3
        ButtonElement.BackgroundColor3 = Color3.fromRGB(
            originalColor.R * 255 - 10,
            originalColor.G * 255 - 8,
            originalColor.B * 255 - 6
        )
        task.wait(0.08)
