    function self:SaveConfig(configName)
        if not configName or configName == "" then
            self:Notify("Config Error", "Nama config tidak boleh kosong!", 3)
            return false
        end
        
        local configData = {
            name = configName,
            theme = self.CurrentTheme,
            savedAt = os.date("%Y-%m-%d %H:%M:%S"),
            tabs = {}
        }
        
        -- Save all toggle states
        for tabIndex, tab in ipairs(self.Tabs) do
            local tabData = {name = tab.TabName or "Tab " .. tabIndex, toggles = {}}
            for _, element in ipairs(tab.Elements) do
                if element.Type == "toggle" and element.GetValue then
                    tabData.toggles[element.Name] = element.GetValue()
                end
            end
            table.insert(configData.tabs, tabData)
        end
        
        local success, err = pcall(function()
            local json = HttpService:JSONEncode(configData)
            if writefile then
                writefile("RexzLibrary/Configs/" .. configName .. ".json", json)
            end
        end)
        
        if success then
            self.CurrentConfigName = configName
            self:Notify("Config Saved", "Config '" .. configName .. "' berhasil disimpan!", 3)
            return true
        else
            self:Notify("Config Error", "Gagal menyimpan config: " .. tostring(err), 3)
            return false
        end
    end
    
    function self:LoadConfig(configName)
        if not configName then
            local configs = self:ListConfigs()
            if #configs == 0 then
                self:Notify("Config Error", "Tidak ada config yang tersedia!", 3)
                return false
            end
            configName = configs[1]
        end
        
        local success, data = pcall(function()
            if isfile then
                local content = readfile("RexzLibrary/Configs/" .. configName .. ".json")
                return HttpService:JSONDecode(content)
            end
            return nil
        end)
        
        if success and data then
            -- Apply theme
            if data.theme and self.Themes[data.theme] then
                self.CurrentTheme = data.theme
                self.applyTheme()
            end
            
            -- Restore toggle states
            for tabIndex, tabData in ipairs(data.tabs) do
                local tab = self.Tabs[tabIndex]
                if tab then
                    for toggleName, toggleValue in pairs(tabData.toggles) do
                        for _, element in ipairs(tab.Elements) do
                            if element.Type == "toggle" and element.Name == toggleName and element.SetValue then
                                element.SetValue(toggleValue)
                            end
                        end
                    end
                end
            end
            
            self.CurrentConfigName = configName
            self:Notify("Config Loaded", "Config '" .. configName .. "' berhasil dimuat!", 3)
            return true
        else
            self:Notify("Config Error", "Gagal memuat config!", 3)
            return false
        end
    end
    
    function self:ListConfigs()
        local configs = {}
        if listfiles then
            local success, files = pcall(listfiles, "RexzLibrary/Configs/")
            if success and files then
                for _, file in ipairs(files) do
                    local name = file:match("([^/]+)%.json$")
                    if name then
                        table.insert(configs, name)
                    end
                end
            end
        end
        return configs
    end
    
    function self:DeleteConfig(configName)
        if not configName then
            self:Notify("Config Error", "Nama config tidak boleh kosong!", 3)
            return false
        end
        
        local success, err = pcall(function()
            if delfile then
                delfile("RexzLibrary/Configs/" .. configName .. ".json")
            end
        end)
        
        if success then
            if self.CurrentConfigName == configName then
                self.CurrentConfigName = nil
            end
            self:Notify("Config Deleted", "Config '" .. configName .. "' berhasil dihapus!", 3)
            return true
        else
            self:Notify("Config Error", "Gagal menghapus config!", 3)
            return false
        end
    end
    
    function self:GetCurrentConfig()
        return self.CurrentConfigName
    end

