    local Icon = nil
    if iconId then
        Icon = Instance.new("ImageLabel")
        Icon.Name = "ToggleIcon"
        Icon.Size = UDim2.new(0, 14, 0, 14)
        Icon.Position = UDim2.new(0, 10, 0.5, -7)
        Icon.BackgroundTransparency = 1
        Icon.Image = ResolveIcon(iconId)
        Icon.ImageColor3 = lib.Theme.Icon
        Icon.Parent = El
    end

    local Ind = Instance.new("Frame")
    Ind.Name = "IndicatorFrame"
    Ind.Position = UDim2.new(0, iconId and 32 or 12, 0.5, -15) 
    Ind.Size = UDim2.new(0, 30, 0, 30) 
    Ind.BackgroundTransparency = 1 
    Ind.BorderSizePixel = 0
    Ind.Parent = El

    local RLogo = Instance.new("TextLabel")
    RLogo.Name = "RLogo"
    RLogo.Size = UDim2.new(1, 0, 1, 0)
    RLogo.BackgroundTransparency = 1
    RLogo.Text = "R"
    RLogo.TextSize = 22 
    RLogo.Font = Enum.Font.GothamBold
    RLogo.TextXAlignment = Enum.TextXAlignment.Center
    RLogo.TextYAlignment = Enum.TextYAlignment.Center
    RLogo.Parent = Ind

    local Label = Instance.new("TextLabel")
    Label.Name = "ToggleLabel"
    Label.Position = UDim2.new(0, iconId and 72 or 52, 0, 0)
    Label.Size = UDim2.new(1, iconId and -82 or -62, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = text
    Label.TextColor3 = lib.Theme.Text
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamMedium
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = El

    local function UpdateVisual(animate)
        local txtColor = state and Color3.fromRGB(255, 30, 30) or Color3.fromRGB(80, 80, 90)
        local txtTrans = state and 0 or 0.45 

        if animate then
            TweenService:Create(RLogo, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextColor3 = txtColor, TextTransparency = txtTrans }):Play()
        else
            RLogo.TextColor3 = txtColor
            RLogo.TextTransparency = txtTrans
        end
    end

    UpdateVisual(false)

    El.MouseButton1Click:Connect(function()
        state = not state
        lib.ToggleStates[text] = state
        UpdateVisual(true)
        pcall(action, state)
    end)

    lib.ToggleStates[text] = state
    lib.ToggleRegistry[text] = {
        SetState = function(newState, fire)
            state = newState and true or false
            lib.ToggleStates[text] = state
            UpdateVisual(true)
            if fire then pcall(action, state) end
        end
    }

    table.insert(lib.ControlRegistry, { Kind = "Toggle", Root = El, Title = Label, Icon = Icon, Text = Label, Indicator = Ind, RLogo = RLogo, State = state })
    table.insert(self.Elements, { Name = text, Instance = El })
end

