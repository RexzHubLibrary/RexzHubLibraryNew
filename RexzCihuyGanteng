-- ESP Library
function Library:CreateESP(color)
    local espEnabled = false
    local espObjects = {}
    
    local function createESP(part)
        local billboard = Instance.new("BillboardGui")
        billboard.Size = UDim2.new(0, 100, 0, 30)
        billboard.Adornee = part
        billboard.AlwaysOnTop = true
        billboard.Parent = part
        
        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.Text = part.Name
        textLabel.TextColor3 = color or Color3.fromRGB(255, 0, 0)
        textLabel.TextStrokeTransparency = 0.3
        textLabel.TextScaled = true
        textLabel.Parent = billboard
        
        return billboard
    end
    
    function espEnabled:toggle()
        espEnabled = not espEnabled
        if espEnabled then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and v.Parent:FindFirstChild("Humanoid") then
                    table.insert(espObjects, createESP(v))
                end
            end
        else
            for _, v in pairs(espObjects) do
                v:Destroy()
            end
            espObjects = {}
        end
    end
    
    return espEnabled
end

-- Webhook Sender
function Library:SendWebhook(webhookURL, embedData)
    if not isDelta then
        warn("Webhook requires Synapse X or Delta Executor with request support")
        return false
    end
    
    local data = {
        ["username"] = embedData.username or "Rexz Library",
        ["embeds"] = {{
            ["title"] = embedData.title or "",
            ["description"] = embedData.description or "",
            ["color"] = embedData.color or 5814783,
            ["fields"] = embedData.fields or {},
            ["footer"] = embedData.footer or {text = "Rexz Library v3.0"},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    
    local response = syn.request({
        Url = webhookURL,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode(data)
    })
    
    return response
end

-- Save/Load Config
function Library:SaveConfig(configName, data)
    local configString = HttpService:JSONEncode(data)
    writefile(configName .. ".json", configString)
    return true
end

function Library:LoadConfig(configName)
    if isfile(configName .. ".json") then
        local data = readfile(configName .. ".json")
        return HttpService:JSONDecode(data)
    end
    return nil
end

-- Teleport
function Library:Teleport(position)
    local character = Player.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        character.HumanoidRootPart.CFrame = position
    end
end

-- Get All Players
function Library:GetPlayers()
    local players = {}
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= Player then
            table.insert(players, v)
        end
    end
    return players
end

-- Get Distance
function Library:GetDistance(part1, part2)
    return (part1.Position - part2.Position).Magnitude
end

-- Simple Tween
function Library:Tween(obj, properties, duration, style)
    local tweenInfo = TweenInfo.new(duration or 0.5, style or Enum.EasingStyle.Quad)
    local tween = TweenService:Create(obj, tweenInfo, properties)
    tween:Play()
    return tween
end

