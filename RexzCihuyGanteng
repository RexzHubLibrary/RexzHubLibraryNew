    -- ‚ĒÄ‚ĒÄ Minimize / Hide ‚ĒÄ‚ĒÄ
    local function MinimizeWindow()  
        if self.Hidden then return end  
        self.Minimized = not self.Minimized  
        
        local targetSize = self.Minimized and UDim2.new(0, 500, 0, 38) or UDim2.new(0, 500, 0, 320)  
        TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = targetSize }):Play()  
        
        local visibility = not self.Minimized
        
        self.Sidebar.Visible = visibility
        self.SidebarBg.Visible = visibility
        self.SearchFrame.Visible = visibility
        self.ContentHolder.Visible = visibility
        
        local div = MainFrame:FindFirstChild("SidebarDivider")
        if div then div.Visible = visibility end
        
        for _, child in ipairs(self.Sidebar:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("Frame") then
                child.Visible = visibility
            end
        end
        
        for _, child in ipairs(MainFrame:GetChildren()) do
            if child:IsA("TextButton") and child.Name:match("_TabBtn$") then
                child.Visible = visibility
            end
        end
    end  

    local function ToggleHideWindow()
        self.Hidden = not self.Hidden
        if self.Hidden then
            local tw = TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { BackgroundTransparency = 1 })
            tw:Play()
            tw.Completed:Once(function() MainFrame.Visible = false end)
        else
            MainFrame.Visible = true
            MainFrame.BackgroundTransparency = 1
            
            local target = self.Minimized and UDim2.new(0, 500, 0, 38) or UDim2.new(0, 500, 0, 320)
                
            TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Size = target, BackgroundTransparency = 0 }):Play()
                
            if not self.Minimized then
                self.Sidebar.Visible = true
                self.SidebarBg.Visible = true
                self.SearchFrame.Visible = true
                self.ContentHolder.Visible = true
                local div = MainFrame:FindFirstChild("SidebarDivider")
                if div then div.Visible = true end
                
                for _, child in ipairs(self.Sidebar:GetChildren()) do
                    if child:IsA("TextButton") or child:IsA("Frame") then
                        child.Visible = true
                    end
                end
                for _, child in ipairs(MainFrame:GetChildren()) do
                    if child:IsA("TextButton") and child.Name:match("_TabBtn$") then
                        child.Visible = true
                    end
                end
            end
        end
    end

